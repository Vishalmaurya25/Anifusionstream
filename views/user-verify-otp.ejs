<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --primary-amber: #f59e0b;
        --primary-cyan: #06b6d4;
        --text-muted: #9ca3af;
    }

    body {
        background: var(--bg-deep);
        color: #ffffff;
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
    }

    /* Animated background orbs */
    .auth-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .auth-bg::before,
    .auth-bg::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.15;
    }

    .auth-bg::before {
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, #3b82f6, transparent);
        top: -10%;
        right: -10%;
        animation: float 20s ease-in-out infinite;
    }

    .auth-bg::after {
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, #f59e0b, transparent);
        bottom: -15%;
        left: -10%;
        animation: float 25s ease-in-out infinite reverse;
    }

    @keyframes float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(-30px, 30px) scale(1.1); }
        66% { transform: translate(20px, -20px) scale(0.9); }
    }

    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 76px);
        padding: 2rem 1.25rem;
        position: relative;
        z-index: 1;
    }

    /* Glass card */
    .auth-card {
        background: linear-gradient(135deg, rgba(21, 27, 35, 0.9) 0%, rgba(17, 24, 39, 0.9) 100%);
        backdrop-filter: blur(40px) saturate(180%);
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 2.5rem;
        width: 100%;
        max-width: 480px;
        padding: 3rem 2.5rem;
        box-shadow: 
            0 25px 50px -12px rgba(0, 0, 0, 0.8),
            0 0 80px rgba(59, 130, 246, 0.1),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
        position: relative;
        overflow: hidden;
        text-align: center;
    }

    .auth-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -50%;
        width: 200%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.5), transparent);
        animation: shimmer 3s linear infinite;
    }

    @keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    /* Gradient title */
    .auth-title {
        font-size: 2.5rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .auth-title-gradient {
        background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 50%, #f59e0b 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        filter: drop-shadow(0 0 30px rgba(59, 130, 246, 0.5));
    }

    /* OTP Input */
    .otp-group {
        position: relative;
        margin-bottom: 1.5rem;
        text-align: left;
    }

    .otp-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.75rem;
        display: block;
    }

    .otp-input {
        font-size: 2rem;
        font-weight: 900;
        text-align: center;
        letter-spacing: 0.8em;
        background: rgba(28, 35, 45, 0.6);
        border: 2px solid rgba(255, 255, 255, 0.08);
        border-radius: 1.25rem;
        color: white;
        padding: 1.5rem 1rem;
        width: 100%;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Courier New', monospace;
        box-sizing: border-box;
    }

    .otp-input::placeholder {
        color: rgba(156, 163, 175, 0.3);
        letter-spacing: 0.8em;
    }

    .otp-input:focus {
        outline: none;
        border-color: rgba(59, 130, 246, 0.6);
        background: rgba(28, 35, 45, 0.9);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15), 0 10px 30px rgba(59, 130, 246, 0.2);
        transform: translateY(-2px);
    }

    /* Animated dots */
    .otp-hint {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .otp-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(59, 130, 246, 0.3);
        transition: all 0.3s ease;
    }

    .otp-input:focus ~ .otp-hint .otp-dot {
        background: rgba(59, 130, 246, 0.8);
        box-shadow: 0 0 10px rgba(59, 130, 246, 0.6);
        animation: dotPulse 1.5s ease-in-out infinite;
    }

    .otp-dot:nth-child(2) { animation-delay: 0.2s; }
    .otp-dot:nth-child(3) { animation-delay: 0.4s; }
    .otp-dot:nth-child(4) { animation-delay: 0.6s; }
    .otp-dot:nth-child(5) { animation-delay: 0.8s; }
    .otp-dot:nth-child(6) { animation-delay: 1s; }

    @keyframes dotPulse {
        0%, 100% { transform: scale(1); opacity: 0.3; }
        50% { transform: scale(1.5); opacity: 1; }
    }

    /* Gradient button */
    .auth-button {
        background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
        color: #ffffff;
        font-weight: 900;
        padding: 1.25rem;
        border-radius: 1rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 0.875rem;
        border: none;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.2);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .auth-button::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s ease;
    }

    .auth-button:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(59, 130, 246, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    .auth-button:hover::before {
        left: 100%;
    }

    /* Resend section */
    .resend-section {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .resend-text {
        font-size: 0.75rem;
        color: var(--text-muted);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.75rem;
    }

    .resend-button {
        background: rgba(28, 35, 45, 0.6);
        border: 1px solid rgba(59, 130, 246, 0.2);
        color: #3b82f6;
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .resend-button::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(6, 182, 212, 0.1));
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .resend-button:hover {
        border-color: rgba(59, 130, 246, 0.5);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(59, 130, 246, 0.2);
    }

    .resend-button:hover::before {
        opacity: 1;
    }

    @media (max-width: 640px) {
        .auth-card {
            padding: 2.5rem 1.5rem;
            border-radius: 2rem;
        }
        .auth-title {
            font-size: 2rem;
        }
        .otp-input {
            font-size: 1.5rem;
            letter-spacing: 0.5em;
            padding: 1.25rem 0.75rem;
        }
    }
</style>

<div class="auth-bg"></div>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-600 mb-6 shadow-lg shadow-blue-500/50">
            <i class="fas fa-fingerprint text-white text-2xl"></i>
        </div>
        <h1 class="auth-title">
            Verify <span class="auth-title-gradient">Identity</span>
        </h1>
        <p class="text-gray-400 mt-3 font-medium">Enter the 6-digit code for password reset</p>
    </div>

    <div class="auth-card">
        <%- include('partials/flash') %>

        <form action="/user/verify-otp" method="POST">
            <div class="otp-group">
                <label class="otp-label">Reset Code</label>
                <input 
                    type="text" 
                    name="otp" 
                    maxlength="6" 
                    class="otp-input" 
                    placeholder="000000" 
                    required 
                    autofocus
                    inputmode="numeric"
                >
                <div class="otp-hint">
                    <div class="otp-dot"></div>
                    <div class="otp-dot"></div>
                    <div class="otp-dot"></div>
                    <div class="otp-dot"></div>
                    <div class="otp-dot"></div>
                    <div class="otp-dot"></div>
                </div>
            </div>

            <button type="submit" class="auth-button">
                <span class="relative z-10 flex items-center justify-center gap-2">
                    <i class="fas fa-shield-check"></i>
                    Verify Identity
                </span>
            </button>
        </form>

        <div class="resend-section">
            <p class="resend-text">Didn't get the reset code?</p>
            <form action="/user/resend-reset-otp" method="POST">
                <button type="submit" class="resend-button">
                    <span class="relative z-10">Resend Reset Code</span>
                </button>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>