<%- include('partials/header') %>
<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --text-muted: #9ca3af;
    }

    body {
        background-color: var(--bg-deep);
        color: #ffffff;
        font-family: 'Inter', sans-serif;
    }

  .admin-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 90vh;
        width: 100%;
        padding: 2rem 1.25rem;
    }

  .ui-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 2rem;
        width: 100%;
        max-width: 600px;
        padding: 3rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

  .ui-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
        display: block;
    }

  .ui-input {
        background-color: var(--input-dark);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 0.85rem;
        color: #ffffff;
        padding: 1.1rem;
        width: 100%;
        transition: all 0.2s ease;
        box-sizing: border-box;
    }

  .ui-input:focus {
        outline: none;
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 1px var(--primary-blue);
    }

  .genre-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 10px;
        background: rgba(0,0,0,0.2);
        padding: 1.25rem;
        border-radius: 1rem;
        border: 1px solid rgba(255,255,255,0.02);
        max-height: 250px;
        overflow-y: auto;
    }

  .genre-item {
        display: flex;
        align-items: center;
        font-size: 0.85rem;
        color: var(--text-muted);
        cursor: pointer;
        transition: color 0.2s;
    }

  .genre-item:hover { color: #fff; }

    input[type="checkbox"] {
        margin-right: 8px;
        accent-color: var(--primary-blue);
        width: 16px;
        height: 16px;
        cursor: pointer;
    }

  .ui-button {
        background-color: var(--primary-blue);
        color: #ffffff;
        font-weight: 700;
        padding: 1.1rem;
        border-radius: 0.85rem;
        width: 100%;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border: none;
        cursor: pointer;
    }

  .ui-button:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
    }

  .back-link {
        color: var(--primary-blue);
        font-size: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        margin-bottom: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

  .back-link:hover {
        text-decoration: underline;
        color: #60a5fa;
    }

    /* NEW: Type Selector Styles */
  .type-selector {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 2rem;
    }

  .type-option {
        background: var(--input-dark);
        border: 2px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        padding: 1.25rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
        position: relative;
    }

  .type-option input[type="radio"] {
        position: absolute;
        opacity: 0;
    }

  .type-option:hover {
        border-color: rgba(59, 130, 246, 0.3);
        background: rgba(59, 130, 246, 0.05);
    }

  .type-option.active {
        border-color: var(--primary-blue);
        background: rgba(59, 130, 246, 0.1);
    }

  .type-icon {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }

  .type-label {
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

  .type-desc {
        font-size: 10px;
        color: var(--text-muted);
        margin-top: 0.25rem;
    }

    @media (max-width: 640px) {
      .ui-card { padding: 2rem 1.5rem; }
      .genre-grid { grid-template-columns: repeat(2, 1fr); }
      .type-selector { grid-template-columns: 1fr; }
    }
</style>

<div class="admin-wrapper">

    <div class="text-center mb-10">
        <a href="/admin/dashboard" class="back-link">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Back to Dashboard
        </a>
        <h1 class="text-4xl md:text-5xl font-black tracking-tight">
            Add New <span class="text-blue-500">Anime</span>
        </h1>
    </div>

    <div class="ui-card">
        <%- include('partials/flash') %>

        <form action="/admin/add-anime" method="POST">

            <!-- NEW: Type Selector -->
            <div class="mb-8">
                <label class="ui-label">Content Type</label>
                <div class="type-selector">
                    <label class="type-option active" id="type-series">
                        <input type="radio" name="type" value="series" checked>
                        <div class="type-icon">📺</div>
                        <div class="type-label">TV Series</div>
                        <div class="type-desc">Multiple episodes & seasons</div>
                    </label>
                    <label class="type-option" id="type-movie">
                        <input type="radio" name="type" value="movie">
                        <div class="type-icon">🎬</div>
                        <div class="type-label">Movie</div>
                        <div class="type-desc">Single video file</div>
                    </label>
                </div>
            </div>

            <div class="mb-8">
                <label class="ui-label">Anime Name</label>
                <input type="text" name="name" class="ui-input" placeholder="e.g. Solo Leveling" required maxlength="200">
            </div>

            <div class="mb-8">
                <label class="ui-label">Poster Image URL</label>
                <input type="url" name="imageUrl" class="ui-input" placeholder="https://image-link.com/poster.jpg" required maxlength="500">
            </div>

            <div class="mb-8">
                <label class="ui-label">Description</label>
                <textarea name="description" rows="4" class="ui-input" placeholder="Write a brief synopsis..." required maxlength="2000"></textarea>
            </div>

            <div class="mb-10">
                <label class="ui-label">Select Genres</label>
                <div class="genre-grid">
                    <% if (genres && genres.length > 0) { %>
                        <% genres.forEach(genre => { %>
                            <label class="genre-item">
                                <input type="checkbox" name="genres" value="<%= genre._id %>">
                                <%= genre.name %>
                            </label>
                        <% }) %>
                    <% } else { %>
                        <p class="text-gray-500 text-sm col-span-full text-center">No genres available</p>
                    <% } %>
                </div>
            </div>

            <div class="mb-8">
                <label class="ui-label">Special Information / Announcements</label>
                <textarea name="specialInfo" rows="3" class="ui-input" placeholder="e.g. MORE EPISODE WILL BE ADDED AFTER RELEASE..." maxlength="500"></textarea>
                <p class="text-[10px] text-gray-500 mt-2 italic">Note: This will only appear on the anime page if you write something here.</p>
            </div>

            <button type="submit" class="ui-button">
                Publish to Catalog
            </button>
        </form>
    </div>
</div>

<script>
    // Type selector toggle
    const typeOptions = document.querySelectorAll('.type-option');
    const typeInputs = document.querySelectorAll('input[name="type"]');

    typeOptions.forEach(option => {
        option.addEventListener('click', () => {
            typeOptions.forEach(opt => opt.classList.remove('active'));
            option.classList.add('active');
            option.querySelector('input').checked = true;
        });
    });
</script>

<%- include('partials/footer') %>