<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --primary-amber: #f59e0b;
        --primary-cyan: #06b6d4;
        --text-muted: #9ca3af;
    }

    body {
        background: var(--bg-deep);
        color: #ffffff;
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
    }

    /* Animated background orbs */
    .auth-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .auth-bg::before,
    .auth-bg::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.15;
    }

    .auth-bg::before {
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, #3b82f6, transparent);
        top: -10%;
        left: -10%;
        animation: float 20s ease-in-out infinite;
    }

    .auth-bg::after {
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, #f59e0b, transparent);
        bottom: -15%;
        right: -10%;
        animation: float 25s ease-in-out infinite reverse;
    }

    @keyframes float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(30px, -30px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
    }

    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 76px);
        padding: 2rem 1.25rem;
        position: relative;
        z-index: 1;
    }

    /* Glass card */
    .auth-card {
        background: linear-gradient(135deg, rgba(21, 27, 35, 0.9) 0%, rgba(17, 24, 39, 0.9) 100%);
        backdrop-filter: blur(40px) saturate(180%);
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 2.5rem;
        width: 100%;
        max-width: 480px;
        padding: 3rem 2.5rem;
        box-shadow: 
            0 25px 50px -12px rgba(0, 0, 0, 0.8),
            0 0 80px rgba(59, 130, 246, 0.1),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
        position: relative;
        overflow: hidden;
    }

    .auth-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -50%;
        width: 200%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.5), transparent);
        animation: shimmer 3s linear infinite;
    }

    @keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    /* Back button */
    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.5rem;
        text-decoration: none;
        transition: all 0.3s ease;
        padding: 0.5rem 1rem;
        border-radius: 0.75rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(28, 35, 45, 0.4);
    }

    .back-btn:hover {
        color: #ffffff;
        border-color: rgba(59, 130, 246, 0.3);
        background: rgba(59, 130, 246, 0.1);
        transform: translateX(-3px);
    }

    /* Gradient title */
    .auth-title {
        font-size: 2.5rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .auth-title-gradient {
        background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 50%, #f59e0b 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        filter: drop-shadow(0 0 30px rgba(59, 130, 246, 0.5));
    }

    /* Input with floating label */
    .input-group {
        position: relative;
        margin-bottom: 2rem;
    }

    .input-field {
        background: rgba(28, 35, 45, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1rem;
        color: #ffffff;
        padding: 1.25rem 1rem 1.25rem 3rem;
        width: 100%;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-sizing: border-box;
    }

    .input-field:focus {
        outline: none;
        border-color: rgba(59, 130, 246, 0.5);
        background: rgba(28, 35, 45, 0.8);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1), 0 8px 25px rgba(59, 130, 246, 0.15);
        transform: translateY(-2px);
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        transition: all 0.3s ease;
        pointer-events: none;
    }

    .input-field:focus ~ .input-icon {
        color: var(--primary-blue);
        transform: translateY(-50%) scale(1.1);
    }

    .input-label {
        position: absolute;
        left: 3rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.3s ease;
        pointer-events: none;
        background: var(--input-dark);
        padding: 0 0.5rem;
    }

    .input-field:focus ~ .input-label,
    .input-field:not(:placeholder-shown) ~ .input-label {
        top: 0;
        font-size: 0.65rem;
        color: var(--primary-blue);
    }

    /* Gradient button */
    .auth-button {
        background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
        color: #ffffff;
        font-weight: 900;
        padding: 1.25rem;
        border-radius: 1rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 0.875rem;
        border: none;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.2);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .auth-button::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s ease;
    }

    .auth-button:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(59, 130, 246, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    .auth-button:hover::before {
        left: 100%;
    }

    .auth-button:active {
        transform: translateY(-1px);
    }

    @media (max-width: 640px) {
        .auth-card {
            padding: 2.5rem 1.5rem;
            border-radius: 2rem;
        }
        .auth-title {
            font-size: 2rem;
        }
    }
</style>

<div class="auth-bg"></div>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-600 mb-6 shadow-lg shadow-blue-500/50">
            <i class="fas fa-key text-white text-2xl"></i>
        </div>
        <h1 class="auth-title">
            Account <span class="auth-title-gradient">Recovery</span>
        </h1>
        <p class="text-gray-400 mt-3 font-medium">Verify your email to reset security</p>
    </div>

    <div class="auth-card">
        <a href="/user/login" class="back-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Login
        </a>

        <%- include('partials/flash') %>

        <form action="/user/forgot-password" method="POST">
            <div class="input-group">
                <input type="email" name="email" id="email" class="input-field" placeholder=" " required>
                <label for="email" class="input-label">Registered Email</label>
                <i class="fas fa-envelope input-icon"></i>
            </div>

            <button type="submit" class="auth-button">
                <span class="relative z-10 flex items-center justify-center gap-2">
                    <i class="fas fa-paper-plane"></i>
                    Send Security Code
                </span>
            </button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>