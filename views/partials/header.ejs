<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Watch your favorite anime series online. Explore by genre, seasons, and episodes.">
    <title>AniFusionStream</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #0b0e11;
            --accent-pink: #ec4899;
            --accent-purple: #a855f7;
            --accent-blue: #3b82f6;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-deep);
            padding-top: 76px;
        }

        /* Animated gradient logo */
    .logo-gradient {
            background: linear-gradient(135deg, #ec4899 0%, #a855f7 50%, #3b82f6 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: inline-block;
            animation: gradientShift 4s ease infinite;
            filter: drop-shadow(0 0 20px rgba(236, 72, 153, 0.5));
        }

        @keyframes gradientShift {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

    .logo-gradient:hover {
            filter: drop-shadow(0 0 30px rgba(168, 85, 247, 0.8));
            transform: scale(1.05);
        }

        /* Glass navbar with glow */
    .glass-nav {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.95) 0%, rgba(15, 23, 42, 0.85) 100%);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-bottom: 1px solid rgba(236, 72, 153, 0.1);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3), 0 0 40px rgba(236, 72, 153, 0.05);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            transition: all 0.3s ease;
        }

        /* Nav links with underline animation */
    .nav-link {
            position: relative;
            font-size: 0.875rem;
            font-weight: 700;
            color: #cbd5e1;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.5rem 0;
        }

    .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #ec4899, #a855f7);
            transition: all 0.3s ease;
            transform: translateX(-50%);
            border-radius: 2px;
        }

    .nav-link:hover {
            color: #ffffff;
            text-shadow: 0 0 20px rgba(236, 72, 153, 0.5);
        }

    .nav-link:hover::after {
            width: 100%;
            box-shadow: 0 0 10px rgba(236, 72, 153, 0.8);
        }

        /* CTA Button glow */
    .cta-btn {
            background: linear-gradient(135deg, #ec4899 0%, #a855f7 100%);
            box-shadow: 0 4px 15px rgba(236, 72, 153, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.2);
            transition: all 0.3s ease;
        }

    .cta-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(236, 72, 153, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.3);
        }

        /* Hamburger animation */
    .hamburger-line {
            width: 28px;
            height: 3px;
            background: linear-gradient(90deg, #ec4899, #a855f7);
            border-radius: 2px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #hamburger-btn:hover.hamburger-line {
            box-shadow: 0 0 10px rgba(236, 72, 153, 0.8);
        }

        #hamburger-btn.active.line-1 {
            transform: rotate(45deg) translate(8px, 8px);
        }

        #hamburger-btn.active.line-2 {
            opacity: 0;
        }

        #hamburger-btn.active.line-3 {
            transform: rotate(-45deg) translate(7px, -7px);
        }

        /* Mobile menu */
        #mobile-menu {
            transition: transform 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            background: linear-gradient(180deg, #1a1f2e 0%, #0f172a 100%);
            border-left: 1px solid rgba(236, 72, 153, 0.2);
        }

        #mobile-menu-overlay {
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(4px);
            transition: opacity 0.3s ease;
        }

    .mobile-link {
            font-size: 1.125rem;
            font-weight: 800;
            padding: 1.25rem 2rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            display: flex;
            align-items: center;
            gap: 1rem;
            color: #cbd5e1;
            transition: all 0.3s ease;
            position: relative;
        }

    .mobile-link::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            width: 0;
            height: 60%;
            background: linear-gradient(180deg, #ec4899, #a855f7);
            transition: width 0.3s ease;
            transform: translateY(-50%);
            border-radius: 0 4px 4px 0;
        }

    .mobile-link:hover {
            color: #ffffff;
            background: rgba(236, 72, 153, 0.05);
            padding-left: 2.5rem;
        }

    .mobile-link:hover::before {
            width: 4px;
            box-shadow: 0 0 15px rgba(236, 72, 153, 0.8);
        }

    .close-btn {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(236, 72, 153, 0.1);
            border: 1px solid rgba(236, 72, 153, 0.3);
            border-radius: 50%;
            transition: all 0.3s ease;
        }

    .close-btn:hover {
            background: rgba(236, 72, 153, 0.2);
            transform: rotate(90deg);
            box-shadow: 0 0 20px rgba(236, 72, 153, 0.5);
        }

        /* Divider glow */
    .nav-divider {
            width: 1px;
            height: 24px;
            background: linear-gradient(180deg, transparent, rgba(236, 72, 153, 0.5), transparent);
        }

       .icon-svg {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }
    </style>
</head>
<body class="bg-gray-900 text-white">

    <nav class="glass-nav px-4 md:px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">

            <!-- Logo with icon -->
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center shadow-lg shadow-pink-500/50">
                    <svg class="icon-svg text-white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <div class="text-2xl md:text-3xl font-black tracking-tighter">
                    <a href="/" class="logo-gradient">AniFusionStream</a>
                </div>
            </div>

            <!-- Desktop Menu -->
            <div class="hidden md:flex items-center space-x-8">
                <a href="/" class="nav-link">Home</a>
                <a href="/disclaimer" class="nav-link">Disclaimer</a>
                <a href="/dmca" class="nav-link">DMCA</a>
                <a href="/privacy-policy" class="nav-link">Privacy</a>
                <a href="/contact-us" class="nav-link">Contact</a>

                <div class="nav-divider"></div>

                <% if (!isUser &&!isAdmin) { %>
                    <a href="/user/login" class="nav-link">Login</a>
                    <a href="/user/register" class="cta-btn px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest">
                        Register
                    </a>
                <% } else { %>
                    <% if (isAdmin) { %>
                        <a href="/admin/dashboard" class="nav-link text-yellow-400 hover:text-yellow-300 flex items-center gap-2">
                            <svg class="icon-svg" viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                            Dashboard
                        </a>
                    <% } %>

                    <% if (isUser) { %>
                        <form action="/user/logout" method="POST" class="inline">
                            <button type="submit" class="nav-link text-red-400 hover:text-red-300 flex items-center gap-2">
                                <svg class="icon-svg" viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2.9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                                Logout
                            </button>
                        </form>
                    <% } %>

                    <% if (isAdmin) { %>
                        <form action="/admin/logout" method="POST" class="inline">
                            <button type="submit" class="nav-link text-red-400 hover:text-red-300 flex items-center gap-2">
                                <svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
                                Admin Logout
                            </button>
                        </form>
                    <% } %>
                <% } %>
            </div>

            <!-- Animated Hamburger -->
            <button id="hamburger-btn" class="md:hidden flex flex-col gap-1.5 p-2">
                <span class="hamburger-line line-1"></span>
                <span class="hamburger-line line-2"></span>
                <span class="hamburger-line line-3"></span>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu-overlay" class="fixed inset-0 z-[1090] hidden md:hidden opacity-0"></div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="fixed top-0 right-0 bottom-0 w-[85%] max-w-sm translate-x-full z-[1100] md:hidden shadow-2xl flex flex-col">

        <div class="p-6 flex justify-between items-center border-b border-pink-500/10">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center">
                    <svg class="icon-svg text-white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <span class="text-xl font-black logo-gradient">Menu</span>
            </div>
            <button id="close-menu-btn" class="close-btn">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="flex flex-col py-4">
            <a href="/" class="mobile-link">
                <svg class="icon-svg text-pink-500 w-5" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
                <span>Home</span>
            </a>

            <% if (isAdmin) { %>
                <a href="/admin/dashboard" class="mobile-link">
                    <svg class="icon-svg text-yellow-500 w-5" viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                    <span>Admin Dashboard</span>
                </a>
            <% } %>

            <a href="/disclaimer" class="mobile-link">
                <svg class="icon-svg text-purple-500 w-5" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
                <span>Disclaimer</span>
            </a>
            <a href="/dmca" class="mobile-link">
                <svg class="icon-svg text-blue-500 w-5" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
                <span>DMCA</span>
            </a>
            <a href="/privacy-policy" class="mobile-link">
    <svg class="icon-svg text-green-500 w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
    </svg>
    <span>Privacy Policy</span>
</a>
            <a href="/contact-us" class="mobile-link">
                <svg class="icon-svg text-yellow-500 w-5" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                <span>Contact Us</span>
            </a>
        </div>

        <div class="mt-auto p-6 space-y-3 mb-6">
            <% if (!isUser &&!isAdmin) { %>
                <a href="/user/login" class="block text-center py-4 bg-gray-800/50 border border-gray-700 rounded-xl font-black uppercase tracking-widest text-sm hover:bg-gray-700 transition-all">
                    <svg class="icon-svg inline mr-2" viewBox="0 0 24 24"><path d="M11 7L9.6 8.4l2.6 2.6H2v2h10.2l-2.6 2.6L11 17l5-5-5-5zm9 12h-8v2h8c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-8v2h8v14z"/></svg>Login
                </a>
                <a href="/user/register" class="block text-center py-4 bg-gradient-to-r from-pink-600 to-purple-600 rounded-xl font-black uppercase tracking-widest text-sm shadow-lg shadow-pink-500/50">
                    <svg class="icon-svg inline mr-2" viewBox="0 0 24 24"><path d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>Register
                </a>
            <% } else { %>
                <% if (isUser) { %>
                    <form action="/user/logout" method="POST">
                        <button type="submit" class="w-full text-center py-4 bg-red-600/20 text-red-400 border border-red-600/30 rounded-xl font-black uppercase tracking-widest text-sm hover:bg-red-600/30 transition-all">
                            <svg class="icon-svg inline mr-2" viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2.9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>Logout Account
                        </button>
                    </form>
                <% } %>

                <% if (isAdmin) { %>
                    <form action="/admin/logout" method="POST">
                        <button type="submit" class="w-full text-center py-4 bg-red-600/20 text-red-400 border border-red-600/30 rounded-xl font-black uppercase tracking-widest text-sm hover:bg-red-600/30 transition-all">
                            <svg class="icon-svg inline mr-2" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>Admin Logout
                        </button>
                    </form>
                <% } %>
            <% } %>
        </div>
    </div>

    <script>
        const openBtn = document.getElementById('hamburger-btn');
        const closeBtn = document.getElementById('close-menu-btn');
        const menu = document.getElementById('mobile-menu');
        const overlay = document.getElementById('mobile-menu-overlay');

        function toggleMenu(open) {
            if (open) {
                menu.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 10);
                openBtn.classList.add('active');
                document.body.style.overflow = 'hidden';
            } else {
                menu.classList.add('translate-x-full');
                overlay.classList.remove('opacity-100');
                setTimeout(() => overlay.classList.add('hidden'), 300);
                openBtn.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        }

        openBtn.addEventListener('click', () => toggleMenu(true));
        closeBtn.addEventListener('click', () => toggleMenu(false));
        overlay.addEventListener('click', () => toggleMenu(false));

        document.querySelectorAll('.mobile-link').forEach(link => {
            link.addEventListener('click', () => toggleMenu(false));
        });

        // Navbar scroll effect
        let lastScroll = 0;
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.glass-nav');
            const currentScroll = window.pageYOffset;

            if (currentScroll > 50) {
                nav.style.boxShadow = '0 8px 32px rgba(0, 0, 0, 0.4), 0 0 60px rgba(236, 72, 153, 0.1)';
            } else {
                nav.style.boxShadow = '0 4px 30px rgba(0, 0, 0, 0.3), 0 0 40px rgba(236, 72, 153, 0.05)';
            }
            lastScroll = currentScroll;
        });
    </script>