<style>
  .icon-svg {
        width: 1.2em;
        height: 1.2em;
        fill: currentColor;
        flex-shrink: 0;
    }

    /* Premium Hover Effects */
 .footer-link-pill {
        background: #1f2937;
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 12px 20px;
        border-radius: 14px;
        color: #efefef;
        font-size: 0.85rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Inter', sans-serif;
    }

 .footer-link-pill:hover {
        background: #2d3748;
        border-color: #facc15;
        transform: translateX(8px);
        color: #ffffff;
    }

 .footer-link-pill.active {
        border-color: rgba(59, 130, 246, 0.5);
        background: rgba(59, 130, 246, 0.1);
    }

    /* Social Buttons Styling */
 .social-vibrant-btn {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 15px;
        color: #FFFFFF!important;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        text-decoration: none;
    }

 .social-vibrant-btn:hover {
        transform: translateY(-8px) rotate(5deg);
        filter: brightness(1.2);
        box-shadow: 0 15px 30px rgba(0,0,0,0.5);
    }

 .social-vibrant-btn.icon-svg {
        width: 28px;
        height: 28px;
    }

    /* High Visibility Copyright Styles */
 .copyright-text {
        color: #FFFFFF!important;
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 5px;
        font-family: 'Inter', sans-serif;
    }

 .brand-text {
        color: #3b82f6;
        text-shadow: 0 0 15px rgba(59, 130, 246, 0.3);
    }

 .slogan-text {
        color: #9ca3af;
        letter-spacing: 5px;
        font-weight: 600;
    }

    @media (max-width: 640px) {
     .copyright-text {
            letter-spacing: 1px;
            font-size: 11px;
        }
     .social-vibrant-btn {
            width: 45px;
            height: 45px;
        }
     .social-vibrant-btn.icon-svg {
            width: 24px;
            height: 24px;
        }
    }
</style>

