<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AniFusionStream</title>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body {
  height: 100%;
}

body {
  background: #0a0b0f;
  color: #fff;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background-image:
    radial-gradient(ellipse at 20% 30%, rgba(59, 130, 246, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 70%, rgba(139, 92, 246, 0.12) 0%, transparent 50%);
}

.gradient-orb {
  position: fixed;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.3;
  pointer-events: none;
  animation: orbFloat 20s ease-in-out infinite;
}

.orb-1 {
  width: 500px;
  height: 500px;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  top: -200px;
  left: -200px;
}

.orb-2 {
  width: 400px;
  height: 400px;
  background: linear-gradient(135deg, #f59e0b, #ef4444);
  bottom: -150px;
  right: -150px;
  animation-delay: -10s;
}

@keyframes orbFloat {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(30px, -30px) scale(1.1); }
}

#particles {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.particle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  animation: gentleRise 15s linear infinite;
  opacity: 0.4;
}

@keyframes gentleRise {
  0% { transform: translateY(100vh) scale(0.5); opacity: 0; }
  10% { opacity: 0.4; }
  90% { opacity: 0.4; }
  100% { transform: translateY(-10vh) scale(1); opacity: 0; }
}

.center {
  position: relative;
  z-index: 10;
  text-align: center;
  padding: 40px;
  max-width: 700px;
  width: 100%;
}

.logo-wrapper {
  margin-bottom: 48px;
  animation: fadeInUp 0.8s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.icon-badge {
  width: 100px;
  height: 100px;
  margin: 0 auto 32px;
  border-radius: 24px;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20px 60px rgba(59, 130, 246, 0.4), 
              inset 0 1px 0 rgba(255, 255, 255, 0.2);
  position: relative;
  animation: float 3s ease-in-out infinite;
}

.icon-badge::after {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 24px;
  background: linear-gradient(135deg, #60a5fa, #a78bfa);
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s;
}

.icon-badge:hover::after {
  opacity: 1;
}

.icon-badge i {
  font-size: 48px;
  color: white;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.welcome-text {
  font-size: 12px;
  letter-spacing: 4px;
  opacity: 0.6;
  margin-bottom: 12px;
  text-transform: uppercase;
  font-weight: 600;
  color: #94a3b8;
  animation: fadeInUp 0.8s ease-out 0.1s both;
}

.brand {
  font-size: 3.5rem;
  font-weight: 900;
  line-height: 1.1;
  margin: 0 0 16px;
  background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 50%, #fbbf24 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: -2px;
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

.subtitle {
  color: #64748b;
  margin: 0 0 48px;
  font-size: 1.05rem;
  font-weight: 500;
  letter-spacing: 0.3px;
  line-height: 1.6;
  animation: fadeInUp 0.8s ease-out 0.3s both;
}

.enter-btn {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 18px 42px;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  border-radius: 16px;
  color: white;
  text-decoration: none;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  font-size: 14px;
  box-shadow: 0 10px 40px rgba(59, 130, 246, 0.35);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.1);
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

.enter-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.enter-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 15px 50px rgba(59, 130, 246, 0.5);
  border-color: rgba(255, 255, 255, 0.2);
}

.enter-btn:hover::before {
  opacity: 1;
}

.enter-btn:active {
  transform: translateY(0);
}

.features {
  display: flex;
  justify-content: center;
  gap: 32px;
  margin-top: 56px;
  animation: fadeInUp 0.8s ease-out 0.5s both;
}

.feature {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  opacity: 0.7;
  transition: opacity 0.3s;
}

.feature:hover {
  opacity: 1;
}

.feature i {
  font-size: 24px;
  color: #60a5fa;
}

.feature span {
  font-size: 12px;
  font-weight: 600;
  color: #64748b;
  letter-spacing: 0.5px;
}

@media (max-width: 768px) {
  .brand { font-size: 2.5rem; letter-spacing: -1px; }
  .welcome-text { font-size: 11px; letter-spacing: 3px; }
  .subtitle { font-size: 0.95rem; margin-bottom: 40px; padding: 0 20px; }
  .icon-badge { width: 80px; height: 80px; border-radius: 20px; }
  .icon-badge i { font-size: 38px; }
  .enter-btn { padding: 16px 36px; font-size: 13px; }
  .features { gap: 24px; margin-top: 48px; }
  .feature i { font-size: 20px; }
  .feature span { font-size: 11px; }
}

@media (max-width: 420px) {
  .brand { font-size: 2rem; }
  .features { gap: 20px; }
}
</style>
</head>
<body>
  <div class="gradient-orb orb-1"></div>
  <div class="gradient-orb orb-2"></div>
  <div id="particles"></div>

  <main class="center">
    <div class="logo-wrapper">
      <div class="icon-badge">
        <i class="fas fa-play"></i>
      </div>
    </div>

    <div class="welcome-text">Welcome to</div>
    <h1 class="brand">AniFusionStream</h1>
    <p class="subtitle">Stream unlimited anime in 4K Dual Audio<br>Your gateway to endless adventures</p>
    
    <a href="/home" class="enter-btn">
      <span>Enter Stream</span>
      <i class="fas fa-arrow-right"></i>
    </a>

    <div class="features">
      <div class="feature">
        <i class="fas fa-hd-video"></i>
        <span>4K Quality</span>
      </div>
      <div class="feature">
        <i class="fas fa-language"></i>
        <span>Dual Audio</span>
      </div>
      <div class="feature">
        <i class="fas fa-bolt"></i>
        <span>Fast Stream</span>
      </div>
    </div>
  </main>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Subtle particles only
  const particlesContainer = document.getElementById('particles');
  const colors = ['#3b82f6', '#8b5cf6', '#fbbf24'];
  
  for (let i = 0; i < 30; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    const size = Math.random() * 3 + 2;
    p.style.width = size + 'px';
    p.style.height = size + 'px';
    p.style.left = Math.random() * 100 + 'vw';
    p.style.top = Math.random() * 100 + 'vh';
    const color = colors[Math.floor(Math.random() * colors.length)];
    p.style.background = color;
    p.style.boxShadow = `0 0 ${8 + Math.random() * 8}px ${color}`;
    p.style.animationDuration = (Math.random() * 8 + 12) + 's';
    p.style.animationDelay = (Math.random() * 15) + 's';
    particlesContainer.appendChild(p);
  }
});
</script>
</body>
</html>