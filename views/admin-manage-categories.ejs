<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --inner-navy: #1c232d;
        --primary-blue: #3b82f6;
    }

    body { background-color: var(--bg-deep); color: #ffffff; font-family: 'Inter', sans-serif; }

    .obsidian-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border-radius: 1.5rem;
        transition: all 0.3s ease;
    }

    .ui-input {
        background-color: var(--inner-navy);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 0.75rem;
        color: #ffffff;
        padding: 0.75rem 1rem;
        outline: none;
    }

    .ui-input:focus { border-color: var(--primary-blue); }

    .btn-action {
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.2s;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        color: #9ca3af;
    }

    .btn-action:hover { transform: scale(1.1); color: white; border-color: var(--primary-blue); }
    
    .edit-form-container { display: none; } /* Hidden by default */
</style>

<div class="container mx-auto px-4 py-12 max-w-6xl">
    
    <div class="mb-12">
      <a href="/admin/dashboard" class="text-blue-500 text-xs font-bold mb-4 inline-block hover:underline">← BACK TO DASHBOARD</a>
        <h1 class="text-4xl font-black tracking-tighter uppercase">Manage <span class="text-blue-500">Categories</span></h1>
    </div>

    <div class="obsidian-card p-6 mb-12">
        <form action="/admin/add-genre" method="POST">
            <div class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-1 w-full">
                    <label class="text-[10px] font-black uppercase text-gray-500 mb-2 block">New Genre Name</label>
                    <input type="text" name="name" class="ui-input w-full" placeholder="e.g. Action" required>
                </div>
                <button type="submit" class="bg-blue-600 px-8 py-3 rounded-xl font-black uppercase text-xs tracking-widest hover:bg-blue-500 transition-all h-[48px]">
                    Register Category
                </button>
            </div>
        </form>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% genres.forEach(genre => { %>
            <div class="obsidian-card p-6" id="card-<%= genre._id %>">
                
                <div class="display-mode flex justify-between items-center mb-6">
                    <h2 class="text-xl font-black text-white uppercase truncate"><%= genre.name %></h2>
                    <div class="flex gap-2">
                        <button onclick="toggleEdit('<%= genre._id %>')" class="btn-action hover:text-blue-400">
                            <i class="fas fa-edit text-sm"></i>
                        </button>
                        <form action="/admin/delete-genre/<%= genre._id %>" method="POST" onsubmit="return confirm('Delete category?');">
                            <button type="submit" class="btn-action hover:text-red-500">
                                <i class="fas fa-trash-alt text-sm"></i>
                            </button>
                        </form>
                    </div>
                </div>

                <div class="edit-form-container" id="edit-<%= genre._id %>">
                    <form action="/admin/edit-genre/<%= genre._id %>" method="POST" class="space-y-3">
                        <label class="text-[9px] font-black uppercase text-blue-500">Rename Category</label>
                        <input type="text" name="name" value="<%= genre.name %>" class="ui-input w-full py-2 text-sm">
                        <div class="flex gap-2">
                            <button type="submit" class="flex-1 bg-blue-600 py-2 rounded-lg font-bold text-[10px] uppercase">Save Changes</button>
                            <button type="button" onclick="toggleEdit('<%= genre._id %>')" class="px-4 bg-white/5 rounded-lg text-[10px] font-bold uppercase">Cancel</button>
                        </div>
                    </form>
                </div>

            </div>
        <% }) %>
    </div>
</div>

<script>
    function toggleEdit(id) {
        const card = document.getElementById('card-' + id);
        const displayDiv = card.querySelector('.display-mode');
        const editDiv = card.querySelector('.edit-form-container');

        if (editDiv.style.display === 'block') {
            editDiv.style.display = 'none';
            displayDiv.style.display = 'flex';
        } else {
            editDiv.style.display = 'block';
            displayDiv.style.display = 'none';
        }
    }
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<%- include('partials/footer') %>