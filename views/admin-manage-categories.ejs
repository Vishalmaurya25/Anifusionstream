<%- include('partials/header') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --inner-navy: #1c232d;
        --primary-blue: #3b82f6;
    }

    body { background-color: var(--bg-deep); color: #ffffff; font-family: 'Inter', sans-serif; }

.obsidian-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(10px);
        border-radius: 1.5rem;
        transition: all 0.3s ease;
        padding: 1.5rem;
        position: relative;
    }

.obsidian-card:hover {
        border-color: rgba(59, 130, 246, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

.ui-input {
        background-color: var(--inner-navy);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 0.75rem;
        color: #ffffff;
        padding: 0.75rem 1rem;
        outline: none;
        transition: all 0.2s;
        width: 100%;
    }

.ui-input:focus {
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

.btn-action {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.2s;
        background: #1c232d;
        border: 2px solid #3b82f6;
        color: #ffffff;
        cursor: pointer;
        font-size: 16px;
        font-weight: 900;
        position: relative;
        z-index: 10;
    }

.btn-action:hover {
        transform: scale(1.1);
        background: #3b82f6;
        box-shadow: 0 0 20px rgba(59, 130, 246, 0.6);
    }

.btn-delete {
        border-color: #ef4444!important;
        color: #ef4444!important;
    }

.btn-delete:hover {
        background: #ef4444!important;
        color: #ffffff!important;
        box-shadow: 0 0 20px rgba(239, 68, 68, 0.6)!important;
    }

.genre-badge {
        background: rgba(59, 130, 246, 0.15);
        border: 1px solid rgba(59, 130, 246, 0.3);
        color: #3b82f6;
        font-size: 9px;
        font-weight: 900;
        padding: 3px 8px;
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-block;
    }

.sequence-badge {
    background: linear-gradient(135deg, #facc15 0%, #f59e0b 100%);
    color: #000;
    font-size: 11px;
    font-weight: 900;
    padding: 4px 10px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    box-shadow: 0 0 15px rgba(250, 204, 21, 0.4);
}

.hidden { display: none!important; }
</style>

<div class="container mx-auto px-4 py-12 max-w-6xl">

    <div class="mb-12">
        <a href="/admin/dashboard" class="text-blue-500 text-xs font-bold mb-4 inline-block hover:underline">← BACK TO DASHBOARD</a>
        <h1 class="text-4xl font-black tracking-tighter uppercase">Manage <span class="text-blue-500">Categories</span></h1>
        <p class="text-gray-500 text-sm font-bold mt-2 uppercase tracking-widest">Total: <span class="text-white"><%= genres.length %></span> Categories</p>
    </div>

    <%- include('partials/flash') %>

    <div class="obsidian-card p-6 mb-12">
        <h3 class="text-lg font-black text-white uppercase tracking-tighter mb-4 flex items-center gap-2">
            <span class="text-blue-500 text-2xl">+</span>
            Add New Category
        </h3>
        <form action="/admin/add-genre" method="POST">
            <div class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-1 w-full">
                    <label class="text-xs font-black uppercase text-gray-500 mb-2 block">Genre Name</label>
                    <input type="text" name="name" class="ui-input" placeholder="e.g. Action, Romance, Horror" required maxlength="30">
                </div>
                <button type="submit" class="bg-blue-600 px-8 py-3 rounded-xl font-black uppercase text-xs tracking-widest hover:bg-blue-500 transition-all h-12 flex items-center gap-2">
                    <span class="text-xl">+</span>
                    Register Category
                </button>
            </div>
        </form>
    </div>

    <% if (genres.length === 0) { %>
        <div class="obsidian-card p-12 text-center border-dashed border-2 border-white/5">
            <div class="text-5xl text-gray-700 mb-4">📁</div>
            <p class="text-gray-600 italic font-medium uppercase text-sm">No categories found. Add your first one above.</p>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% genres.forEach(genre => { %>
                <div class="obsidian-card" id="card-<%= genre._id %>">

                    <!-- View Mode -->
                    <div id="view-<%= genre._id %>">
                        <div class="flex items-start justify-between gap-3 mb-3">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-2">
                                    <h2 class="text-xl font-black text-white uppercase truncate"><%= genre.name %></h2>
                                    <% if (genre.sequence && genre.sequence < 9999) { %>
                                        <span class="sequence-badge">
                                            #<%= genre.sequence %>
                                        </span>
                                    <% } %>
                                </div>
                                <span class="genre-badge">
                                    🎬 ID: <%= genre._id.toString().slice(-6) %>
                                </span>
                            </div>
                            <div class="flex gap-2">
                                <button type="button" data-action="edit" data-id="<%= genre._id %>" class="btn-action" title="Edit">
                                    ✏️
                                </button>
                                <button type="button" data-action="delete" data-id="<%= genre._id %>" data-name="<%= genre.name %>" class="btn-action btn-delete" title="Delete">
                                    🗑️
                                </button>
                            </div>
                        </div>

                        <!-- Sequence Control -->
                        <form action="/admin/update-genre-sequence/<%= genre._id %>" method="POST" class="flex items-center gap-2 pt-3 border-t border-white/5">
                            <label class="text-[10px] font-black uppercase text-gray-500">Order:</label>
                            <input
                                type="number"
                                name="sequence"
                                value="<%= genre.sequence < 9999? genre.sequence : '' %>"
                                placeholder="Auto"
                                min="1"
                                max="999"
                                class="ui-input sequence-input py-1.5 text-sm w-20 text-center"
                            >
                            <button type="submit" class="bg-yellow-500/20 border border-yellow-500/40 text-yellow-400 px-3 py-1.5 rounded-lg text-[10px] font-black uppercase hover:bg-yellow-500/30 transition-all">
                                Set
                            </button>
                        </form>
                    </div>

                    <!-- Edit Mode -->
                    <div id="edit-<%= genre._id %>" class="hidden">
                        <form action="/admin/edit-genre/<%= genre._id %>" method="POST" class="space-y-3">
                            <label class="text-[9px] font-black uppercase text-blue-500 block">Rename Category</label>
                            <input type="text" name="name" value="<%= genre.name %>" class="ui-input py-2 text-sm" required maxlength="30">
                            <div class="flex gap-2">
                                <button type="submit" class="flex-1 bg-blue-600 py-2 rounded-lg font-bold text-xs uppercase hover:bg-blue-500 transition-all">
                                    ✓ Save
                                </button>
                                <button type="button" data-action="cancel" data-id="<%= genre._id %>" class="px-4 bg-white/5 rounded-lg text-xs font-bold uppercase hover:bg-white/10 transition-all">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>

                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<script>
// FIXED: Event delegation with proper bubbling control
document.addEventListener('DOMContentLoaded', function() {

    // Single delegated listener for all buttons
    document.addEventListener('click', function(e) {
        const btn = e.target.closest('[data-action]');
        if (!btn) return;

        e.preventDefault();
        e.stopPropagation();

        const action = btn.getAttribute('data-action');
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');

        if (action === 'edit') {
            showEdit(id);
        } else if (action === 'delete') {
            deleteGenre(id, name);
        } else if (action === 'cancel') {
            hideEdit(id);
        }
    });

    // Show Edit Mode
    function showEdit(id) {
        const viewDiv = document.getElementById('view-' + id);
        const editDiv = document.getElementById('edit-' + id);

        if (viewDiv && editDiv) {
            viewDiv.classList.add('hidden');
            editDiv.classList.remove('hidden');
            const input = editDiv.querySelector('input[name="name"]');
            if (input) {
                input.focus();
                input.select();
            }
        }
    }

    // Hide Edit Mode - CANCEL BUTTON FIXED
    function hideEdit(id) {
        const viewDiv = document.getElementById('view-' + id);
        const editDiv = document.getElementById('edit-' + id);

        if (viewDiv && editDiv) {
            editDiv.classList.add('hidden');
            viewDiv.classList.remove('hidden');
        }
    }

    // Delete Genre
    function deleteGenre(genreId, genreName) {
        Swal.fire({
            title: 'Delete Category?',
            html: `Are you sure you want to delete <b>"${genreName}"</b>?<br><br><span class="text-yellow-500 text-sm">⚠️ This will remove the category from all anime!</span>`,
            icon: 'warning',
            background: '#0b0e11',
            color: '#ffffff',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#1f2937',
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'Cancel',
            customClass: {
                popup: 'rounded-2xl border border-white/10 shadow-2xl'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/admin/delete-genre/${genreId}`;
                document.body.appendChild(form);
                form.submit();
            }
        })
    }

    // Make functions global for backward compatibility
    window.showEdit = showEdit;
    window.hideEdit = hideEdit;
    window.deleteGenre = deleteGenre;
});
</script>

<%- include('partials/footer') %>