<%- include("partials/header") %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --primary-amber: #f59e0b;
        --primary-cyan: #06b6d4;
        --accent-purple: #a855f7;
        --text-main: #ffffff;
        --text-dim: #9ca3af;
    }

    body {
        background: var(--bg-deep);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    /* Animated background orbs */
    .page-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .page-bg::before,
    .page-bg::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.12;
    }

    .page-bg::before {
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, #3b82f6, transparent);
        top: -15%;
        left: -10%;
        animation: float 22s ease-in-out infinite;
    }

    .page-bg::after {
        width: 700px;
        height: 700px;
        background: radial-gradient(circle, #f59e0b, transparent);
        bottom: -20%;
        right: -15%;
        animation: float 28s ease-in-out infinite reverse;
    }

    @keyframes float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(40px, -40px) scale(1.1); }
        66% { transform: translate(-30px, 30px) scale(0.9); }
    }

    .page-container {
        max-width: 720px;
        margin: 0 auto;
        padding: 5rem 1.5rem;
        position: relative;
        z-index: 1;
    }

    /* Glass card with glow */
    .glass-card {
        background: linear-gradient(135deg, rgba(21, 27, 35, 0.9) 0%, rgba(17, 24, 39, 0.9) 100%);
        backdrop-filter: blur(40px) saturate(180%);
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 2.5rem;
        padding: 3.5rem;
        width: 100%;
        margin-bottom: 2.5rem;
        box-shadow: 
            0 25px 50px -12px rgba(0, 0, 0, 0.8),
            0 0 80px rgba(59, 130, 246, 0.08),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
        position: relative;
        overflow: hidden;
    }

    .glass-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -50%;
        width: 200%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.5), transparent);
        animation: shimmer 3s linear infinite;
    }

    @keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    /* Title gradient */
    .page-title {
        font-size: 3rem;
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 1rem;
    }

    .title-gradient {
        background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 50%, #f59e0b 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        filter: drop-shadow(0 0 30px rgba(59, 130, 246, 0.5));
    }

    /* Detail boxes with gradient border */
    .detail-box {
        background: rgba(28, 35, 45, 0.6);
        padding: 2rem;
        border-radius: 1.5rem;
        margin: 2rem 0;
        position: relative;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.4s ease;
    }

    .detail-box::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        border-radius: 2px;
        transition: all 0.4s ease;
    }

    .detail-box:hover {
        transform: translateX(5px);
        background: rgba(28, 35, 45, 0.8);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .box-blue::before {
        background: linear-gradient(180deg, #3b82f6, #06b6d4);
        box-shadow: 0 0 20px rgba(59, 130, 246, 0.6);
    }

    .box-purple::before {
        background: linear-gradient(180deg, #a855f7, #ec4899);
        box-shadow: 0 0 20px rgba(168, 85, 247, 0.6);
    }

    .detail-box:hover::before {
        width: 6px;
        box-shadow: 0 0 30px currentColor;
    }

    .detail-box h3 {
        font-weight: 800;
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
        color: #ffffff;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .detail-box p {
        color: var(--text-dim);
        line-height: 1.8;
        font-size: 0.975rem;
    }

    .box-icon {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .icon-blue {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(6, 182, 212, 0.2));
        border: 1px solid rgba(59, 130, 246, 0.3);
        color: #3b82f6;
    }

    .icon-purple {
        background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(236, 72, 153, 0.2));
        border: 1px solid rgba(168, 85, 247, 0.3);
        color: #a855f7;
    }

    /* Intro text */
    .intro-text {
        font-size: 1.25rem;
        font-weight: 600;
        line-height: 1.7;
        margin-bottom: 2.5rem;
        color: #e5e7eb;
    }

    .body-text {
        color: var(--text-dim);
        line-height: 1.8;
        font-size: 1.05rem;
        margin: 2rem 0;
    }

    .body-text strong {
        color: #ffffff;
        font-weight: 700;
    }

    /* Action buttons */
    .action-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        width: 100%;
        padding: 1.25rem;
        border-radius: 1rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.875rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        position: relative;
        overflow: hidden;
    }

    .btn-glass {
        background: rgba(28, 35, 45, 0.8);
        color: #ffffff;
        margin-bottom: 1rem;
        border: 1px solid rgba(59, 130, 246, 0.2);
        backdrop-filter: blur(10px);
    }

    .btn-glass:hover {
        transform: translateY(-3px);
        border-color: rgba(59, 130, 246, 0.5);
        background: rgba(59, 130, 246, 0.15);
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
    }

    .btn-gradient {
        background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
        color: #ffffff;
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    .btn-gradient::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s ease;
    }

    .btn-gradient:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(59, 130, 246, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    .btn-gradient:hover::before {
        left: 100%;
    }

    .section-header {
        font-size: 2rem;
        font-weight: 900;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-icon {
        width: 3rem;
        height: 3rem;
        border-radius: 1rem;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(6, 182, 212, 0.2));
        border: 1px solid rgba(59, 130, 246, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3b82f6;
    }

    .legal-footer {
        text-align: center;
        color: #6b7280;
        font-size: 0.8rem;
        font-style: italic;
        line-height: 1.8;
        padding: 2rem 1rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.03);
        margin-top: 2rem;
    }

    @media (max-width: 640px) {
        .glass-card {
            padding: 2.5rem 1.5rem;
            border-radius: 2rem;
        }
        .page-title {
            font-size: 2.25rem;
        }
        .section-header {
            font-size: 1.5rem;
        }
        .detail-box {
            padding: 1.5rem;
        }
    }
</style>

<div class="page-bg"></div>

<div class="page-container">
    
