<%- include("partials/header") %>

<!-- Import Rajdhani for the Futuristic Anime/Gaming UI typography -->
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
    :root {
        --bg-deep: #06090e;
        --ui-dark: #0f141e;
        --ui-border: rgba(59, 130, 246, 0.2);
        --neon-blue: #3b82f6;
        --neon-cyan: #06b6d4;
        --neon-yellow: #facc15;
        --neon-red: #ef4444;
        --text-main: #e2e8f0;
        --text-dim: #94a3b8;
    }

    body {
        background: var(--bg-deep);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    .anime-font {
        font-family: 'Rajdhani', sans-serif;
    }

    /* Holographic System Grid Background */
    .system-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-color: var(--bg-deep);
        background-image: 
            linear-gradient(var(--ui-border) 1px, transparent 1px),
            linear-gradient(90deg, var(--ui-border) 1px, transparent 1px);
        background-size: 50px 50px;
        mask-image: radial-gradient(ellipse at bottom left, black 30%, transparent 80%);
        -webkit-mask-image: radial-gradient(ellipse at bottom left, black 30%, transparent 80%);
        opacity: 0.25;
    }

    .main-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 76px);
        padding: 5rem 1.25rem;
        position: relative;
        z-index: 1;
    }

    /* Main Sci-Fi Card */
    .system-card {
        background: rgba(15, 20, 30, 0.85);
        backdrop-filter: blur(12px);
        border: 1px solid var(--ui-border);
        border-top: 3px solid var(--neon-cyan);
        width: 100%;
        max-width: 600px;
        padding: 4rem 3rem;
        margin-bottom: 2.5rem;
        position: relative;
        /* Mecha/Sci-Fi Angled Corners */
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 40px), calc(100% - 40px) 100%, 0 100%);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
    }

    /* Decorative bottom-right corner block */
    .system-card::after {
        content: '';
        position: absolute;
        bottom: 0;
        right: 0;
        width: 40px;
        height: 40px;
        background: var(--ui-border);
        clip-path: polygon(100% 0, 0% 100%, 100% 100%);
    }

    /* Top Left System Badge */
    .system-badge {
        position: absolute;
        top: 0;
        left: 2.5rem;
        background: var(--neon-cyan);
        color: #000;
        padding: 4px 20px;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        clip-path: polygon(0 0, 100% 0, 90% 100%, 10% 100%);
    }

    .page-title {
        font-size: 3.5rem;
        font-weight: 900;
        letter-spacing: 2px;
        line-height: 1.1;
        margin-bottom: 1rem;
        text-transform: uppercase;
        text-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
    }

    .title-gradient {
        background: linear-gradient(135deg, var(--neon-cyan) 0%, var(--neon-blue) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    /* Sci-Fi Inputs */
    .input-group {
        position: relative;
        margin-bottom: 2rem;
    }

    .input-field, .select-field {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid var(--ui-border);
        border-bottom: 2px solid var(--ui-border);
        color: #ffffff;
        padding: 1.25rem 1rem 1.25rem 3rem;
        width: 100%;
        font-size: 1rem;
        font-weight: 500;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-sizing: border-box;
        /* Bottom right tech cut */
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%);
    }

    .select-field {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        cursor: pointer;
        color-scheme: dark;
    }

    .select-field option {
        background: var(--ui-dark);
        color: #ffffff;
        padding: 1rem;
        border: none;
    }

    textarea.input-field {
        padding-top: 1.25rem;
        resize: vertical;
        min-height: 140px;
    }

    /* Glow state on focus */
    .input-field:focus, .select-field:focus {
        outline: none;
        border-color: var(--neon-cyan);
        border-bottom: 2px solid var(--neon-cyan);
        background: rgba(6, 182, 212, 0.05);
        box-shadow: 0 5px 15px rgba(6, 182, 212, 0.15);
        transform: translateY(-2px);
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        top: 1.25rem;
        color: var(--text-dim);
        transition: all 0.3s ease;
        pointer-events: none;
        z-index: 2;
    }

    .input-field:focus ~ .input-icon,
    .select-field:focus ~ .input-icon {
        color: var(--neon-cyan);
        text-shadow: 0 0 10px var(--neon-cyan);
        transform: scale(1.1);
    }

    .input-label {
        position: absolute;
        left: 3rem;
        top: 1.3rem;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: 2px;
        transition: all 0.3s ease;
        pointer-events: none;
        z-index: 2;
    }

    /* Label Float Animation */
    .input-field:focus ~ .input-label,
    .input-field:not(:placeholder-shown) ~ .input-label,
    .select-field:focus ~ .input-label,
    .select-field:valid ~ .input-label {
        top: -0.6rem;
        left: 1rem;
        font-size: 0.7rem;
        color: var(--neon-cyan);
        background: var(--bg-deep);
        padding: 0 0.5rem;
        border-left: 2px solid var(--neon-cyan);
        text-shadow: 0 0 8px rgba(6, 182, 212, 0.5);
    }

    .select-wrapper { position: relative; }
    .select-arrow {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-dim);
        pointer-events: none;
        transition: all 0.3s ease;
        z-index: 2;
    }

    .select-field:focus ~ .select-arrow {
        color: var(--neon-cyan);
        transform: translateY(-50%) rotate(180deg);
    }

    /* Cyberpunk Action Button */
    .action-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        width: 100%;
        background: linear-gradient(90deg, var(--neon-blue), var(--neon-cyan));
        color: #000;
        padding: 1.25rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 1rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: none;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);
        box-shadow: 0 0 20px rgba(6, 182, 212, 0.4);
        margin-top: 1rem;
    }

    .action-btn:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 0 30px rgba(6, 182, 212, 0.6);
        filter: brightness(1.2);
    }

    /* System Alert Messages (Flash) */
    .system-alert {
        padding: 1.25rem;
        margin-bottom: 2rem;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        backdrop-filter: blur(10px);
        animation: slideDown 0.4s ease;
        clip-path: polygon(0 0, 100% 0, 98% 100%, 0% 100%);
        border-left: 4px solid;
    }

    @keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .alert-error {
        background: repeating-linear-gradient(-45deg, rgba(239, 68, 68, 0.05), rgba(239, 68, 68, 0.05) 10px, rgba(0, 0, 0, 0.4) 10px, rgba(0, 0, 0, 0.4) 20px);
        border-color: var(--neon-red);
        color: #fca5a5;
    }

    .alert-success {
        background: repeating-linear-gradient(-45deg, rgba(6, 182, 212, 0.05), rgba(6, 182, 212, 0.05) 10px, rgba(0, 0, 0, 0.4) 10px, rgba(0, 0, 0, 0.4) 20px);
        border-color: var(--neon-cyan);
        color: #cffafe;
    }

    @media (max-width: 640px) {
        .system-card { padding: 3rem 1.5rem; clip-path: polygon(0 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%); }
        .page-title { font-size: 2.5rem; }
        .system-badge { left: 1.5rem; }
    }
</style>

<!-- Background Grid & Accents -->
<div class="system-bg"></div>

<div class="main-wrapper">
    
    <!-- Header Section -->
    <div class="text-center mb-12 relative">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-gray-900 border border-cyan-500/30 mb-6 relative" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); box-shadow: 0 0 30px rgba(6,182,212,0.2);">
            <i class="fas fa-satellite-dish text-cyan-400 text-3xl"></i>
        </div>
        <h1 class="page-title anime-font">
            Contact <span class="title-gradient">Link</span>
        </h1>
        <p class="anime-font text-cyan-400 text-lg font-bold tracking-widest uppercase opacity-80 max-w-md mx-auto">
            // Secure Communication Protocol Initiated
        </p>
    </div>

    <!-- MAIN SYSTEM CARD -->
    <div class="system-card">
        <div class="system-badge anime-font">Comms Link</div>
        
        <!-- Flash Messages -->
        <% if (messages.error) { %>
            <div class="system-alert alert-error anime-font">
                <i class="fas fa-exclamation-triangle mr-2 text-red-500"></i>
                <%= messages.error %>
            </div>
        <% } %>
        <% if (messages.success) { %>
            <div class="system-alert alert-success anime-font">
                <i class="fas fa-check-circle mr-2 text-cyan-400"></i>
                <%= messages.success %>
            </div>
        <% } %>

        <form action="/contact-us" method="POST">
            <!-- Name Input -->
            <div class="input-group">
                <input type="text" name="name" id="name" class="input-field" placeholder=" " required>
                <label for="name" class="input-label anime-font">Designation (Name)</label>
                <i class="fas fa-user input-icon"></i>
            </div>

            <!-- Email Input -->
            <div class="input-group">
                <input type="email" name="email" id="email" class="input-field" placeholder=" " required>
                <label for="email" class="input-label anime-font">Transmission Node (Email)</label>
                <i class="fas fa-envelope input-icon"></i>
            </div>

            <!-- Subject Select -->
            <div class="input-group select-wrapper">
                <select name="subject" id="subject" class="select-field" required>
                     <option value="" disabled selected hidden></option>
                    <option value="Copyright Complaint">⚖️ Copyright Complaint</option>
                    <option value="Anime Suggestion">✨ Anime Suggestion</option>
                    <option value="Dead Link Report">🔗 Dead Link Report</option>
                    <option value="Business Inquiry">💼 Business Inquiry</option>
                    <option value="Other">💬 Other</option>
                </select>
                <label for="subject" class="input-label anime-font">Transmission Subject</label>
                <i class="fas fa-tag input-icon"></i>
                <i class="fas fa-chevron-down select-arrow"></i>
            </div>

            <!-- Message Textarea -->
            <div class="input-group">
                <textarea name="message" id="message" class="input-field" placeholder=" " required></textarea>
                <label for="message" class="input-label anime-font">Message Payload</label>
                <i class="fas fa-comment-dots input-icon"></i>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="action-btn anime-font">
                <i class="fas fa-paper-plane text-black"></i>
                Transmit Data
            </button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>