<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap');
    
    :root {
        --bg-deep: #0a0a0f;
        --card-navy: #14141f;
        --input-dark: #1e1e2e;
        --neon-pink: #ff2e7d;
        --neon-blue: #00d9ff;
        --neon-purple: #b794f6;
        --text-muted: #9ca3af;
    }

    body {
        background: var(--bg-deep);
        color: #ffffff;
        font-family: 'Outfit', sans-serif;
        overflow-x: hidden;
    }

    /* Subtle gradient background - no heavy animation */
    .auth-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
        background: 
            radial-gradient(circle at 20% 30%, rgba(255, 46, 125, 0.08) 0%, transparent 50%),
            radial-gradient(circle at 80% 70%, rgba(0, 217, 255, 0.08) 0%, transparent 50%);
    }

    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 76px);
        padding: 2rem 1.25rem;
        position: relative;
        z-index: 1;
    }

    /* Clean card with subtle glow */
    .auth-card {
        background: linear-gradient(135deg, rgba(20, 20, 31, 0.95) 0%, rgba(14, 14, 20, 0.95) 100%);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 46, 125, 0.15);
        border-radius: 1.5rem;
        width: 100%;
        max-width: 480px;
        padding: 3rem 2.5rem;
        box-shadow: 
            0 20px 40px -12px rgba(0, 0, 0, 0.6),
            0 0 40px rgba(255, 46, 125, 0.08);
    }

    /* Title - anime style but readable */
    .auth-title {
        font-size: 2.5rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .auth-title-gradient {
        background: linear-gradient(135deg, var(--neon-pink) 0%, var(--neon-blue) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .subtitle {
        color: var(--text-muted);
        font-size: 0.95rem;
        font-weight: 600;
        margin-top: 0.75rem;
    }

    /* Input styling */
    .input-group {
        position: relative;
        margin-bottom: 1.75rem;
    }

    .input-field {
        background: rgba(30, 30, 46, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 0.75rem;
        color: #ffffff;
        padding: 1.25rem 3rem 1.25rem 3rem;
        width: 100%;
        font-size: 0.95rem;
        font-weight: 600;
        transition: all 0.2s ease;
        box-sizing: border-box;
    }

    .input-field:focus {
        outline: none;
        border-color: var(--neon-pink);
        background: rgba(30, 30, 46, 1);
        box-shadow: 0 0 0 3px rgba(255, 46, 125, 0.1);
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        transition: all 0.2s ease;
        pointer-events: none;
    }

    .input-field:focus ~ .input-icon {
        color: var(--neon-pink);
    }

    .input-label {
        position: absolute;
        left: 3rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.2s ease;
        pointer-events: none;
        background: var(--input-dark);
        padding: 0 0.5rem;
    }

    .input-field:focus ~ .input-label,
    .input-field:not(:placeholder-shown) ~ .input-label {
        top: 0;
        font-size: 0.65rem;
        color: var(--neon-pink);
    }

    /* Password toggle */
    .password-toggle {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        transition: all 0.2s ease;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 0.5rem;
    }

    .password-toggle:hover {
        color: var(--neon-blue);
        background: rgba(0, 217, 255, 0.1);
    }

    /* Clean button */
    .auth-button {
        background: linear-gradient(135deg, var(--neon-pink) 0%, var(--neon-purple) 100%);
        color: #ffffff;
        font-weight: 900;
        padding: 1.25rem;
        border-radius: 0.75rem;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 0.875rem;
        border: none;
        cursor: pointer;
        box-shadow: 0 8px 20px rgba(255, 46, 125, 0.3);
        transition: all 0.3s ease;
    }

    .auth-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 30px rgba(255, 46, 125, 0.4);
    }

    .auth-button:active {
        transform: translateY(0);
    }

    /* Links */
    .auth-link {
        color: var(--text-muted);
        font-size: 0.875rem;
        font-weight: 700;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .auth-link:hover {
        color: var(--neon-pink);
    }

    .auth-link-primary {
        background: linear-gradient(135deg, var(--neon-pink), var(--neon-blue));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-weight: 800;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255, 46, 125, 0.1);
        border: 1px solid rgba(255, 46, 125, 0.2);
        color: var(--neon-pink);
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    @media (max-width: 640px) {
        .auth-card {
            padding: 2.5rem 1.5rem;
            border-radius: 1.25rem;
        }
        .auth-title {
            font-size: 2rem;
        }
    }
</style>

<div class="auth-bg"></div>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <div class="badge mb-6">
            <i class="fas fa-play-circle"></i>
            <span>Stream Now</span>
        </div>
        <h1 class="auth-title">
            Join <span class="auth-title-gradient">AniFusionstream</span>
        </h1>
        <p class="subtitle">Create your account - Watch anime in Hindi, English & more</p>
    </div>

    <div class="auth-card">
        <%- include('partials/flash') %>

        <form action="/user/register" method="POST">
            <!-- Username Input -->
            <div class="input-group">
                <input type="text" name="username" id="username" class="input-field" placeholder=" " required autocomplete="username">
                <label for="username" class="input-label">Username</label>
                <i class="fas fa-user input-icon"></i>
            </div>

            <!-- Email Input -->
            <div class="input-group">
                <input type="email" name="email" id="email" class="input-field" placeholder=" " required autocomplete="email">
                <label for="email" class="input-label">Email Address</label>
                <i class="fas fa-envelope input-icon"></i>
            </div>

            <!-- Password Input -->
            <div class="input-group">
                <input type="password" name="password" id="password" class="input-field" placeholder=" " required autocomplete="new-password">
                <label for="password" class="input-label">Password</label>
                <i class="fas fa-lock input-icon"></i>
                <button type="button" id="toggle-password" class="password-toggle">
                    <svg id="eye-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                </button>
            </div>

            <button type="submit" class="auth-button mt-2">
                Create Account
            </button>

            <div class="mt-8 text-center">
                <p class="text-gray-400 text-sm font-semibold">
                    Already have an account? 
                    <a href="/user/login" class="auth-link-primary ml-1">Log in</a>
                </p>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const togglePassword = document.getElementById('toggle-password');
        const passwordInput = document.getElementById('password');
        const eyeIcon = document.getElementById('eye-icon');

        if (togglePassword && passwordInput && eyeIcon) {
            togglePassword.addEventListener('click', () => {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);

                if (type === 'text') {
                    eyeIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />`;
                } else {
                    eyeIcon.innerHTML = `
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    `;
                }
            });
        }
    });
</script>

<%- include('partials/footer') %>