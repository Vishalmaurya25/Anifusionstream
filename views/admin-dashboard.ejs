<%- include('partials/header') %>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | AniFusionStream</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #0b0e11;
            --card-navy: #151b23;
            --inner-navy: #1c232d;
            --primary-blue: #3b82f6;
            --text-muted: #9ca3af;
        }

        body {
            background-color: var(--bg-deep);
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .obsidian-card {
            background-color: var(--card-navy);
            backdrop-filter: blur(10px);
            border-radius: 2rem;
            transition: all 0.3s ease;
        }

        .inner-obsidian {
            background-color: var(--inner-navy);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 1.25rem;
        }

        .premium-btn {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .premium-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
        }

        .anime-poster {
            width: 140px;
            height: 200px;
            object-fit: cover;
            border-radius: 1.25rem;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
        }

        .ep-thumbnail {
            width: 100px;
            height: 60px;
            object-fit: cover;
            border-radius: 0.75rem;
            background: var(--inner-navy);
        }

        .custom-scroll::-webkit-scrollbar { width: 5px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
        
        /* Dropdown Animation */
        @keyframes suggestionDrop { 
            0% { opacity: 0; transform: translateY(-10px) scale(0.98); } 
            100% { opacity: 1; transform: translateY(0) scale(1); } 
        }
        .animate-suggestion-drop { animation: suggestionDrop 0.2s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
    </style>
</head>
<body class="py-8 px-4 md:px-12">
    <div class="max-w-7xl mx-auto">

        <header class="flex flex-col md:flex-row justify-between items-center mb-16 gap-8">
            <div class="text-center md:text-left">
                <h1 class="text-5xl font-black tracking-tighter text-white">
                    ADMIN <span class="text-blue-500">CORE</span>
                </h1>
                <p class="text-gray-500 font-bold mt-2 uppercase tracking-widest text-[11px]">
                    System Status: <span class="text-green-500">Operational</span> • <span class="text-white"><%= totalAnimes %></span> Titles Online
                </p>
            </div>
            <div class="flex flex-wrap items-center justify-center gap-4">
                <a href="/admin/add-anime" class="premium-btn bg-blue-600 text-white px-6 py-3 rounded-2xl text-[11px] shadow-lg shadow-blue-600/20">Create Anime</a>
                <a href="/admin/manage-categories" class="premium-btn bg-white/5 border border-white/10 text-white px-6 py-3 rounded-2xl text-[11px] hover:bg-white/10">Categories</a>

                <form action="/admin/logout" method="POST" class="inline">
                    <button type="submit" class="premium-btn bg-red-600/10 text-red-500 border border-red-600/30 px-6 py-3 rounded-2xl text-[11px] hover:bg-red-600 hover:text-white transition-all">
                        Terminate Session
                    </button>
                </form>
            </div>
        </header>

        <%- include('partials/flash') %>

        <section class="mb-20">
            <div class="flex items-center justify-center gap-3 mb-8">
                <div class="w-1.5 h-8 bg-blue-500 rounded-full shadow-[0_0_15px_rgba(59,130,246,0.5)]"></div>
                <h2 class="text-2xl font-black text-white uppercase tracking-tight">System Reports & Support</h2>
            </div>

            <% if (typeof userMessages !== 'undefined' && userMessages.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
                    <% userMessages.forEach(msg => { %>
                        <div class="obsidian-card p-8 relative overflow-hidden group">
                            <span class="text-[9px] font-black uppercase tracking-tighter bg-blue-600/20 text-blue-400 px-3 py-1 rounded-full mb-4 inline-block">
                                <%= msg.subject || 'General Inquiry' %>
                            </span>

                            <h3 class="font-bold text-xl text-white mb-1"><%= msg.name %></h3>
                            <p class="text-xs text-gray-500 mb-6"><%= msg.email %></p>

                            <div class="inner-obsidian p-4 h-32 overflow-y-auto text-sm text-gray-400 custom-scroll leading-relaxed mb-6">
                                <%= msg.message %>
                            </div>

                            <button type="button"
                                    data-action="delete-message"
                                    data-message-id="<%= msg._id %>"
                                    class="w-full py-3 rounded-xl bg-white/5 text-gray-500 hover:bg-red-600 hover:text-white text-[10px] font-black uppercase tracking-widest transition-all">
                                Clear Report
                            </button>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="obsidian-card p-12 text-center border-dashed border-2 border-white/5 max-w-2xl mx-auto">
                    <div class="text-5xl text-gray-700 mb-4">✓</div>
                    <p class="text-gray-600 italic font-medium">System is clear. No pending user reports.</p>
                </div>
            <% } %>
        </section>

        <section>
            <div class="flex items-center gap-3 mb-6">
                <div class="w-1.5 h-8 bg-blue-500 rounded-full shadow-[0_0_15px_rgba(59,130,246,0.5)]"></div>
                <h2 class="text-2xl font-black text-white uppercase tracking-tight">Catalog Intelligence</h2>
            </div>

            <!-- SEARCH AND FILTER FORM -->
            <form method="GET" action="/admin/dashboard" class="mb-10 flex flex-col md:flex-row gap-4 bg-white/5 p-4 rounded-2xl border border-white/10 shadow-lg relative">
                
                <!-- Search Input with Suggestions -->
                <div class="flex-1 relative">
                    <!-- Search Icon -->
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </div>

                    <input type="text" name="q" id="admin-search-input" value="<%= searchQuery %>" placeholder="Search anime by name..." autocomplete="off"
                        class="w-full bg-[#0b0e11] border border-white/10 rounded-xl pl-12 pr-4 py-3.5 text-sm text-white focus:outline-none focus:border-blue-500 placeholder:text-gray-600 font-semibold transition-all">
                    
                    <!-- Suggestions Dropdown -->
                    <div id="admin-suggestions" class="absolute z-[999] w-full bg-[#0a0e12]/95 backdrop-blur-2xl rounded-xl mt-2 overflow-hidden shadow-2xl border border-blue-500/20 hidden animate-suggestion-drop"></div>
                </div>
                
                <div class="md:w-64 relative">
                    <select name="filter" class="w-full bg-[#0b0e11] border border-white/10 rounded-xl px-4 py-3.5 text-sm text-white font-semibold focus:outline-none focus:border-blue-500 appearance-none cursor-pointer transition-all">
                        <option value="all" <%= currentFilter === 'all' ? 'selected' : '' %>>All Catalog</option>
                        <option value="series_all" <%= currentFilter === 'series_all' ? 'selected' : '' %>>Series - All</option>
                        <option value="series_with_ep" <%= currentFilter === 'series_with_ep' ? 'selected' : '' %>>Series - With Episodes</option>
                        <option value="series_without_ep" <%= currentFilter === 'series_without_ep' ? 'selected' : '' %>>Series - Without Episodes</option>
                        <option value="movie_all" <%= currentFilter === 'movie_all' ? 'selected' : '' %>>Movies - All</option>
                        <option value="movie_with_ep" <%= currentFilter === 'movie_with_ep' ? 'selected' : '' %>>Movies - Uploaded</option>
                        <option value="movie_without_ep" <%= currentFilter === 'movie_without_ep' ? 'selected' : '' %>>Movies - Empty (No Source)</option>
                    </select>
                    <!-- Dropdown Arrow Icon -->
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-400">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                    </div>
                </div>
                
                <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white font-black uppercase tracking-wider text-xs py-3.5 px-8 rounded-xl transition-all shadow-lg shadow-blue-500/20">
                    Apply Filter
                </button>
                
                <% if(searchQuery || currentFilter !== 'all') { %>
                    <a href="/admin/dashboard" class="flex items-center justify-center bg-red-600/10 border border-red-500/20 text-red-500 hover:bg-red-600 hover:text-white font-black uppercase tracking-wider text-xs py-3.5 px-6 rounded-xl transition-all">
                        Clear
                    </a>
                <% } %>
            </form>

            <% if (animes.length === 0) { %>
                <div class="obsidian-card p-16 text-center border-dashed border-2 border-white/5 max-w-4xl mx-auto">
                    <div class="text-6xl text-gray-700 mb-6">∅</div>
                    <h3 class="text-2xl font-black text-white uppercase tracking-tighter mb-2">No Records Found</h3>
                    <p class="text-gray-500">No titles match your current search or filter criteria.</p>
                </div>
            <% } else { %>
                <div class="space-y-10">
                    <% animes.forEach(anime => { %>
                        <div class="obsidian-card overflow-hidden">
                            <div class="p-8 md:p-10 flex flex-col md:flex-row gap-10 items-center md:items-start bg-gradient-to-br from-white/5 to-transparent">
                                <img src="<%= anime.imageUrl || 'https://via.placeholder.com/140x200' %>" class="anime-poster border border-white/10" alt="Poster">

                                <div class="flex-1 text-center md:text-left">
                                    <div class="flex flex-wrap justify-center md:justify-start gap-2 mb-4">
                                        <% if(anime.genres && anime.genres.length > 0) { %>
                                            <% anime.genres.forEach(genre => { %>
                                                <span class="bg-blue-600/10 text-blue-400 px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border-blue-500/20">
                                                    <%= genre.name %>
                                                </span>
                                            <% }) %>
                                        <% } %>
                                        <span class="bg-<%= anime.type === 'movie' ? 'red' : 'purple' %>-600/10 text-<%= anime.type === 'movie' ? 'red' : 'purple' %>-400 px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border-<%= anime.type === 'movie' ? 'red' : 'purple' %>-500/20">
                                            <%= anime.type %>
                                        </span>
                                    </div>
                                    <h2 class="text-4xl font-black mb-3 text-white tracking-tight"><%= anime.name %></h2>
                                    <p class="text-gray-500 text-sm leading-relaxed line-clamp-2 max-w-4xl mb-8"><%= anime.description %></p>

                                    <div class="flex flex-wrap justify-center md:justify-start gap-4">
                                        <a href="/admin/edit-anime/<%= anime._id %>" class="premium-btn bg-blue-600 text-white px-6 py-3 rounded-2xl text-[11px] shadow-lg shadow-blue-600/20">Edit Metadata</a>
                                        <a href="/admin/add-episode/<%= anime._id %>" class="premium-btn bg-white/5 border border-white/10 text-white px-6 py-3 rounded-2xl text-[11px] hover:bg-white/10">Add Episode</a>
                                        <button type="button"
                                                data-action="delete-anime"
                                                data-anime-id="<%= anime._id %>"
                                                data-anime-name="<%= anime.name %>"
                                                class="premium-btn bg-red-600/10 text-red-500 px-6 py-3 rounded-2xl text-[11px] border border-red-500/20 hover:bg-red-600 hover:text-white transition-all">
                                            Delete Series
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="p-8 md:p-10 bg-black/20 border-t border-white/5">
                                <% if(anime.seasons && anime.seasons.length > 0) { %>
                                    <% anime.seasons.forEach(season => { %>
                                        <div class="mb-12 last:mb-0">
                                            <div class="flex items-center justify-between gap-6 mb-8">
                                                <div class="flex items-center gap-6 flex-1">
                                                    <h4 class="text-lg font-black text-white uppercase tracking-tighter"><%= anime.type === 'movie' ? 'Movie Media' : `Season ${season.seasonNumber}` %></h4>
                                                    <div class="flex-1 h-px bg-white/5"></div>
                                                </div>
                                                <button type="button"
                                                        data-action="delete-season"
                                                        data-anime-id="<%= anime._id %>"
                                                        data-season-id="<%= season._id %>"
                                                        data-season-num="<%= season.seasonNumber %>"
                                                        data-episode-count="<%= season.episodes.length %>"
                                                        class="premium-btn bg-red-600/10 text-red-500 px-4 py-2 rounded-xl text-[9px] border border-red-500/20 hover:bg-red-600 hover:text-white transition-all">
                                                    <svg class="w-3 h-3 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                                    Clear Batch
                                                </button>
                                            </div>

                                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                                <% if(season.episodes && season.episodes.length > 0) { %>
                                                    <% season.episodes.forEach(episode => { %>
                                                        <div class="inner-obsidian p-5 hover:border-blue-500/50 transition-all">
                                                            <div class="flex gap-5 items-center">
                                                                <img src="<%= episode.imageUrl || 'https://via.placeholder.com/100x60' %>" class="ep-thumbnail" alt="Ep">

                                                                <div class="flex-1 min-w-0">
                                                                    <h5 class="font-black text-[9px] text-blue-500 uppercase mb-0.5"><%= anime.type === 'movie' ? 'FILM' : `EP ${episode.episodeNumber}` %></h5>
                                                                    <p class="font-bold text-white text-sm truncate"><%= episode.title %></p>
                                                                </div>

                                                                <div class="flex gap-2">
                                                                    <a href="/admin/edit-episode/<%= episode._id %>"
                                                                       class="bg-blue-600/20 hover:bg-blue-600 text-blue-400 hover:text-white p-2.5 rounded-lg transition-all border border-blue-500/30 hover:border-blue-500 hover:scale-110"
                                                                       title="Edit Media">
                                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                                                        </svg>
                                                                    </a>

                                                                    <button type="button"
                                                                            data-action="delete-episode"
                                                                            data-episode-id="<%= episode._id %>"
                                                                            data-episode-num="<%= episode.episodeNumber %>"
                                                                            class="bg-red-600/20 hover:bg-red-600 text-red-500 hover:text-white p-2.5 rounded-lg transition-all border border-red-500/30 hover:border-red-500 hover:scale-110"
                                                                            title="Delete Media">
                                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                                                        </svg>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    <% }) %>
                                                <% } else { %>
                                                    <p class="text-gray-600 text-xs italic">No media uploaded yet.</p>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="text-center py-4">
                                        <p class="text-gray-600 text-sm italic uppercase tracking-widest">Structural metadata missing for seasons/media.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>

            <!-- PAGINATION CONTROLS -->
            <% if (totalPages > 1) { %>
                <div class="mt-10 flex flex-col md:flex-row items-center justify-between gap-6 bg-white/5 p-4 md:p-6 rounded-2xl border border-white/10 shadow-xl">
                    
                    <div class="text-gray-400 text-sm font-semibold uppercase tracking-widest text-center md:text-left">
                        Showing page <span class="text-white font-black"><%= currentPage %></span> of <span class="text-white font-black"><%= totalPages %></span> 
                        <span class="opacity-50">|</span> <span class="text-blue-500 font-black"><%= totalAnimes %></span> Total Titles
                    </div>
                    
                    <div class="flex items-center gap-3 w-full md:w-auto justify-between md:justify-end">
                        
                        <!-- Previous Page -->
                        <% if (currentPage > 1) { %>
                            <a href="?q=<%= searchQuery %>&filter=<%= currentFilter %>&page=<%= currentPage - 1 %>" class="px-5 py-2.5 bg-[#0b0e11] rounded-xl border border-white/10 hover:border-blue-500 hover:text-blue-400 transition-all font-black text-xs uppercase tracking-wider">
                                ← Prev
                            </a>
                        <% } else { %>
                            <span class="px-5 py-2.5 bg-black/20 rounded-xl border border-white/5 text-gray-600 font-black text-xs uppercase tracking-wider cursor-not-allowed">← Prev</span>
                        <% } %>
                        
                        <!-- Direct Page Jump -->
                        <form action="/admin/dashboard" method="GET" class="flex items-center gap-2 m-0 relative">
                            <input type="hidden" name="q" value="<%= searchQuery %>">
                            <input type="hidden" name="filter" value="<%= currentFilter %>">
                            <select name="page" onchange="this.form.submit()" class="bg-blue-600 hover:bg-blue-500 text-white border-0 rounded-xl px-4 py-2.5 font-black text-xs uppercase tracking-wider focus:outline-none cursor-pointer appearance-none text-center shadow-lg shadow-blue-500/20 transition-all pl-6 pr-8">
                                <% for(let i = 1; i <= totalPages; i++) { %>
                                    <option value="<%= i %>" class="bg-[#0b0e11]" <%= i === currentPage ? 'selected' : '' %>>Jump to <%= i %></option>
                                <% } %>
                            </select>
                            <!-- Custom dropdown arrow -->
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-white">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
                            </div>
                        </form>

                        <!-- Next Page -->
                        <% if (currentPage < totalPages) { %>
                            <a href="?q=<%= searchQuery %>&filter=<%= currentFilter %>&page=<%= currentPage + 1 %>" class="px-5 py-2.5 bg-[#0b0e11] rounded-xl border border-white/10 hover:border-blue-500 hover:text-blue-400 transition-all font-black text-xs uppercase tracking-wider">
                                Next →
                            </a>
                        <% } else { %>
                            <span class="px-5 py-2.5 bg-black/20 rounded-xl border border-white/5 text-gray-600 font-black text-xs uppercase tracking-wider cursor-not-allowed">Next →</span>
                        <% } %>

                    </div>
                </div>
            <% } %>

        </section>

    </div>

    <%- include('partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', function() {

    
    // DEBOUNCED SEARCH SUGGESTIONS (ADMIN)
    
    const searchInput = document.getElementById('admin-search-input');
    const suggestionsDiv = document.getElementById('admin-suggestions');
    let searchTimeout;

    if (searchInput && suggestionsDiv) {
        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.trim();
            clearTimeout(searchTimeout);

            if (query.length < 2) {
                suggestionsDiv.classList.add('hidden');
                suggestionsDiv.innerHTML = '';
                return;
            }

            // Show skeleton loader
            suggestionsDiv.classList.remove('hidden');
            suggestionsDiv.innerHTML = `
                <div class="p-4 animate-pulse space-y-4">
                    <div class="flex gap-3 items-center"><div class="w-4 h-4 rounded-full bg-blue-500/20"></div><div class="h-4 bg-white/10 rounded w-3/4"></div></div>
                    <div class="flex gap-3 items-center"><div class="w-4 h-4 rounded-full bg-blue-500/20"></div><div class="h-4 bg-white/10 rounded w-1/2"></div></div>
                </div>
            `;

            // Debounce API call
            searchTimeout = setTimeout(async () => {
                try {
                    const res = await fetch(`/api/search-suggestions?q=${encodeURIComponent(query)}`);
                    const results = await res.json();
                    
                    suggestionsDiv.innerHTML = '';
                    if (results.length === 0) {
                        suggestionsDiv.innerHTML = `<div class="p-4 text-gray-400 text-sm font-medium text-center">No matching anime found</div>`;
                        return;
                    }

                    results.forEach(a => {
                        const div = document.createElement('div');
                        div.className = 'p-3 hover:bg-blue-500/10 cursor-pointer text-white text-sm font-semibold transition-all border-b border-white/5 flex items-center gap-3';
                        div.innerHTML = `<svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg> ${a.name}`;
                        
                        // When clicked, fill input and submit form to filter dashboard
                        div.onclick = () => {
                            searchInput.value = a.name;
                            suggestionsDiv.classList.add('hidden');
                            searchInput.closest('form').submit(); 
                        };
                        suggestionsDiv.appendChild(div);
                    });
                } catch (err) {
                    suggestionsDiv.innerHTML = `<div class="p-4 text-red-400 text-sm font-medium text-center">Failed to load suggestions</div>`;
                }
            }, 300);
        });

        // Hide dropdown if clicked outside
        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !suggestionsDiv.contains(e.target)) {
                suggestionsDiv.classList.add('hidden');
            }
        });
    }

    
    // ACTION DELEGATION & SWEETALERTS
    
    document.addEventListener('click', function(e) {
        const btn = e.target.closest('[data-action]');
        if (!btn) return;

        e.preventDefault();
        e.stopPropagation();

        const action = btn.getAttribute('data-action');

        if (action === 'delete-episode') {
            const episodeId = btn.getAttribute('data-episode-id');
            const episodeNum = btn.getAttribute('data-episode-num');
            deleteEpisode(episodeId, episodeNum);
        } else if (action === 'delete-season') {
            const animeId = btn.getAttribute('data-anime-id');
            const seasonId = btn.getAttribute('data-season-id');
            const seasonNum = btn.getAttribute('data-season-num');
            const episodeCount = btn.getAttribute('data-episode-count');
            deleteSeason(animeId, seasonId, seasonNum, episodeCount);
        } else if (action === 'delete-anime') {
            const animeId = btn.getAttribute('data-anime-id');
            const animeName = btn.getAttribute('data-anime-name');
            deleteAnime(animeId, animeName);
        } else if (action === 'delete-message') {
            const messageId = btn.getAttribute('data-message-id');
            deleteMessage(messageId);
        }
    });

    function deleteEpisode(episodeId, episodeNum) {
        Swal.fire({
            title: 'Delete Media?',
            html: `Are you sure you want to delete <b>Media/Episode ${episodeNum}</b>?<br><br><span class="text-red-500 text-sm">⚠️ This action cannot be undone!</span>`,
            icon: 'warning',
            background: '#0b0e11',
            color: '#ffffff',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#1f2937',
            confirmButtonText: 'Yes, Delete!',
            cancelButtonText: 'Cancel',
            customClass: { popup: 'rounded-2xl border-white/10 shadow-2xl' }
        }).then((result) => {
            if (result.isConfirmed) {
                showLoading();
                submitForm(`/admin/delete-episode/${episodeId}`);
            }
        });
    }

    function deleteSeason(animeId, seasonId, seasonNum, episodeCount) {
        Swal.fire({
            title: 'Delete Batch?',
            html: `Are you sure you want to delete this batch?<br><br><span class="text-red-500 text-sm">⚠️ All ${episodeCount} media files will be permanently deleted!</span>`,
            icon: 'warning',
            background: '#0b0e11',
            color: '#ffffff',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#1f2937',
            confirmButtonText: 'Yes, Delete!',
            cancelButtonText: 'Cancel',
            customClass: { popup: 'rounded-2xl border border-white/10 shadow-2xl' }
        }).then((result) => {
            if (result.isConfirmed) {
                showLoading();
                submitForm(`/admin/delete-season/${animeId}/${seasonId}`);
            }
        });
    }

    function deleteAnime(animeId, animeName) {
        Swal.fire({
            title: 'Delete Entire Series?',
            html: `Are you sure you want to delete <b>"${animeName}"</b>?<br><br><span class="text-red-500 text-sm">⚠️ All seasons and episodes will be permanently deleted!</span>`,
            icon: 'warning',
            background: '#0b0e11',
            color: '#ffffff',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#1f2937',
            confirmButtonText: 'Yes, Delete!',
            cancelButtonText: 'Cancel',
            customClass: { popup: 'rounded-2xl border border-white/10 shadow-2xl' }
        }).then((result) => {
            if (result.isConfirmed) {
                showLoading();
                submitForm(`/admin/delete-anime/${animeId}`);
            }
        });
    }

    function deleteMessage(messageId) {
        Swal.fire({
            title: 'Archive Report?',
            html: `Are you sure you want to clear this report?<br><br><span class="text-yellow-500 text-sm">⚠️ This will permanently delete the message.</span>`,
            icon: 'question',
            background: '#0b0e11',
            color: '#ffffff',
            showCancelButton: true,
            confirmButtonColor: '#3b82f6',
            cancelButtonColor: '#1f2937',
            confirmButtonText: 'Yes, Clear!',
            cancelButtonText: 'Cancel',
            customClass: { popup: 'rounded-2xl border border-white/10 shadow-2xl' }
        }).then((result) => {
            if (result.isConfirmed) {
                showLoading();
                submitForm(`/admin/delete-message/${messageId}`);
            }
        });
    }

    function showLoading() {
        Swal.fire({
            title: 'Processing...',
            text: 'Please wait',
            allowOutsideClick: false,
            background: '#0b0e11',
            color: '#ffffff',
            didOpen: () => {
                Swal.showLoading();
            }
        });
    }

    function submitForm(action) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = action;
        document.body.appendChild(form);
        form.submit();
    }
});
</script>

</body>
</html>