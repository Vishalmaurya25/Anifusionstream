<%- include('partials/header') %>

<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mx-auto px-2 md:px-8">

    <div class="mt-4 mb-4 md:mt-8 md:mb-6 flex justify-center relative px-3 md:px-0">
        <form action="/search" method="GET" id="search-form" class="w-full max-w-2xl">
            <div class="search-modern flex items-center gap-2 px-4 py-2 md:py-2.5">

                <input type="text" name="q" id="search-input"
                    value="<%= typeof searchQuery!== 'undefined'? searchQuery : '' %>"
                    placeholder="Search anime..."
                    class="bg-transparent text-white text-sm md:text-base w-full py-2 focus:outline-none font-semibold placeholder:text-gray-600"
                    autocomplete="off">

                <!-- Search Icon Button -->
                <button type="submit" class="flex-shrink-0 p-2 md:p-2.5 rounded-xl bg-gradient-to-br from-blue-600 to-blue-500 hover:from-blue-500 hover:to-blue-400 text-white transition-all hover:scale-105 active:scale-95 shadow-lg shadow-blue-500/30">
                    <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </button>

                <div class="h-5 w-px bg-white/10 flex-shrink-0"></div>

                <!-- CUSTOM DROPDOWN - SUPER GLOWING ARROW -->
                <div class="custom-genre-dropdown relative flex-shrink-0">
    <input type="hidden" name="genre" id="genre-input" value="<%= typeof selectedGenre!== 'undefined'? selectedGenre : '' %>">
    <button type="button" id="genre-toggle" class="group bg-transparent text-gray-400 text-[9px] md:text-xs font-black focus:outline-none cursor-pointer hover:text-blue-400 transition-colors uppercase tracking-wider px-2 py-1 rounded-lg flex items-center gap-1.5 select-none">
        <span id="genre-label"><%= selectedGenre? genres.find(g => g._id.toString() === selectedGenre)?.name || 'Genre' : 'Genre' %></span>
        <!-- DROPDOWN ARROW ICON - BADA AUR CLEAR -->
        <svg class="w-3.5 h-3.5 transition-all duration-300 flex-shrink-0 text-blue-400" id="genre-arrow" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
    </button>

                    <div id="genre-menu" class="absolute right-0 top-full mt-2 w-52 max-h-72 overflow-y-auto bg-[#0a0e12] rounded-xl border border-blue-500/20 shadow-2xl shadow-blue-500/10 hidden will-change-transform">
                        <!-- Top Scroll Indicator - GLOWING -->
                        <div class="sticky top-0 left-0 right-0 h-8 bg-gradient-to-b from-[#0a0e12] via-[#0a0e12]/98 to-transparent pointer-events-none z-10 flex items-start justify-center pt-2">
                            <svg class="w-6 h-6 text-blue-400 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7"></path>
                            </svg>
                        </div>

                        <ul class="pb-2">
                            <li class="genre-option px-3 py-2.5 text-xs font-bold text-gray-300 hover:bg-blue-500/15 hover:text-blue-400 cursor-pointer transition-all border-b border-white/5" data-value="">
                                All Genres
                            </li>
                            <% genres.forEach(genre => { %>
                                <li class="genre-option px-3 py-2.5 text-xs font-bold text-gray-300 hover:bg-blue-500/15 hover:text-blue-400 cursor-pointer transition-all border-b border-white/5 <%= selectedGenre === genre._id.toString()? 'bg-blue-500/10 text-blue-400' : '' %>"
                                    data-value="<%= genre._id %>">
                                    <%= genre.name %>
                                </li>
                            <% }) %>
                        </ul>

                        <!-- Bottom Scroll Indicator - GLOWING -->
                        <div class="sticky bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-[#0a0e12] via-[#0a0e12]/98 to-transparent pointer-events-none z-10 flex items-end justify-center pb-2">
                            <svg class="w-6 h-6 text-blue-400 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <div id="suggestions" class="absolute z-[9998] w-full max-w-2xl left-1/2 -translate-x-1/2 bg-[#0a0e12]/98 backdrop-blur-2xl rounded-2xl mt-2 overflow-hidden shadow-2xl border border-blue-500/20 hidden animate-suggestion-drop"></div>
        </form>
    </div>

    <% if (typeof isSearchResult!== 'undefined' && isSearchResult) { %>
        <div class="mb-8 glass-panel p-4 md:p-6 rounded-2xl md:rounded-3xl">
            <div class="flex justify-between items-center mb-4 md:mb-6">
                <h2 class="text-lg md:text-xl font-black text-white uppercase tracking-tighter">
                    <span class="text-blue-500">Results:</span> <%= animes.length %> Found
                </h2>
                <a href="/" class="text-[9px] font-black bg-red-600/20 text-red-500 border border-red-500/30 px-3 py-1.5 rounded-full hover:bg-red-600 hover:text-white transition-all">
                    CLEAR SEARCH X
                </a>
            </div>

            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-3 md:gap-4">
                <% animes.forEach(anime => { %>
                    <div class="anime-card-glass rounded-xl md:rounded-2xl p-1.5 transition-all">
                        <a href="/anime/<%= anime._id %>">
                            <img src="<%= anime.imageUrl %>" alt="<%= anime.name %>" class="w-full aspect-[2/3] object-cover rounded-lg md:rounded-xl shadow-lg">
                            <p class="text-center mt-2 text-white font-bold text-[11px] md:text-sm line-clamp-2 leading-tight h-7 md:h-10 px-1">
                                <%= anime.name %>
                            </p>
                        </a>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } %>

    <%- include('animation') %>

    <!-- WATCH HISTORY SECTION -->
    <section id="watch-history-section" class="mt-8 mb-8 md:mt-12 md:mb-12 hidden">
        <div class="flex items-center justify-between mb-4 md:mb-6">
            <div class="flex items-center gap-2">
                <div class="w-1 h-5 md:w-1.5 md:h-8 bg-purple-600 rounded-full shadow-[0_0_10px_rgba(147,51,234,0.5)]"></div>
                <h2 class="text-base md:text-2xl font-black text-white tracking-tight">Continue Watching</h2>
            </div>
            <button type="button" id="clear-history-btn" class="text-[10px] md:text-xs font-black bg-red-600/20 text-red-500 border border-red-500/30 px-3 py-1.5 rounded-full hover:bg-red-600 hover:text-white transition-all flex items-center gap-1">
                🗑️ <span class="hidden sm:inline">CLEAR</span>
            </button>
        </div>

        <div id="watch-history-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-6">
            <!-- JS will populate -->
        </div>
    </section>

    <!-- LATEST EPISODES - MOVIE BADGE FIXED -->
    <% if (latestEpisodes && latestEpisodes.length > 0) { %>
    <section class="mt-8 mb-8 md:mt-12 md:mb-12">
        <div class="flex items-center gap-2 mb-4 md:mb-6">
            <div class="w-1 h-5 md:w-1.5 md:h-8 bg-blue-600 rounded-full shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
            <h2 class="text-base md:text-2xl font-black text-white tracking-tight">Latest Release</h2>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-6">
            <% latestEpisodes.slice(0, 20).forEach(function(episode, index) { %>
                <div class="episode-glass-card group cursor-pointer p-1.5 rounded-lg md:rounded-xl border border-white/5 transition-all <%= index >= 9? 'hidden lg:block' : '' %>"
                     data-anime-id="<%= episode.anime? episode.anime._id : '' %>"
                     data-anime-name="<%= episode.anime? episode.anime.name : 'Unknown' %>"
                     data-anime-img="<%= episode.anime && episode.anime.imageUrl? episode.anime.imageUrl : '/images/default.png' %>"
                     data-season="<%= episode.seasonNumber %>"
                     data-episode="<%= episode.episodeNumber %>"
                     data-type="<%= episode.anime && episode.anime.type === 'movie'? 'movie' : 'series' %>">
                    <a href="/anime/<%= episode.anime? episode.anime._id : '' %>" class="block">
                        <div class="relative aspect-video overflow-hidden rounded-md md:rounded-lg">
                            <img src="<%= episode.anime && episode.anime.imageUrl? episode.anime.imageUrl : '/images/default.png' %>"
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">

                            <% if(episode.anime && episode.anime.type === 'movie') { %>
                                <div class="absolute top-1 left-1 md:top-1.5 md:left-1.5 bg-red-600/90 backdrop-blur-md text-[9px] md:text-[10px] font-black text-white px-2 py-0.5 rounded border border-white/10 uppercase">
                                    MOVIE
                                </div>
                            <% } else { %>
                                <div class="absolute top-1 left-1 md:top-1.5 md:left-1.5 bg-black/80 backdrop-blur-md text-[9px] md:text-[10px] font-black text-white px-2 py-0.5 rounded border border-white/10 uppercase">
                                    S<%= episode.seasonNumber %> E<%= episode.episodeNumber %>
                                </div>
                            <% } %>
                        </div>

                        <div class="mt-2 text-center">
                            <h3 class="text-white text-xs md:text-sm font-bold line-clamp-2 leading-tight h-8 md:h-10">
                                <%= episode.anime? episode.anime.name : 'Unknown Anime' %>
                            </h3>
                            <p class="text-gray-500 text-[10px] md:text-[11px] uppercase font-black tracking-wider mt-0.5">
                                <% if(episode.anime && episode.anime.type === 'movie') { %>
                                    Film
                                <% } else { %>
                                    ep <%= episode.episodeNumber %>
                                <% } %>
                            </p>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </section>
    <% } %>

    <% if (typeof isSearchResult === 'undefined' ||!isSearchResult) { %>

    <!-- LATEST GENRES -->
    <% if(latestGenres && latestGenres.length > 0) { %>
    <section class="mb-8">
        <div class="flex items-center gap-2 mb-4 md:mb-6">
            <div class="w-1 h-5 md:w-1.5 md:h-8 bg-blue-600 rounded-full shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
            <h2 class="text-base md:text-2xl font-black text-white tracking-tight">Latest Updates</h2>
        </div>

        <% latestGenres.forEach(genre => {
            let genreAnimes = animes.filter(anime => anime.genres.some(g => g._id.toString() === genre._id.toString()));
            genreAnimes.sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
            if(genreAnimes.length > 0) { %>
            <div class="mb-6 md:mb-10">
                <div class="flex justify-between items-center mb-3 px-1">
                    <div class="flex items-center gap-2">
                        <div class="text-blue-500 font-black text-lg md:text-xl">#</div>
                        <h2 class="text-sm md:text-xl font-black text-white tracking-tight capitalize">
                            <%= genre.name %>
                        </h2>
                    </div>
                    <a href="/search?genre=<%= genre._id %>" class="text-gray-500 text-[10px] md:text-[11px] font-black uppercase tracking-widest hover:text-white transition-colors">
                        View All →
                    </a>
                </div>

                <div class="anime-scroll flex gap-3 md:gap-5 overflow-x-auto pb-4 snap-x">
                    <% genreAnimes.forEach(anime => { %>
                        <div class="anime-card-glass flex-shrink-0 w-[130px] sm:w-[140px] md:w-48 snap-center p-1 md:p-1.5 rounded-xl">
                            <a href="/anime/<%= anime._id %>" class="group">
                                <div class="relative rounded-lg md:rounded-2xl overflow-hidden border border-white/5 shadow-2xl">
                                    <img src="<%= anime.imageUrl %>" class="w-full aspect-[2/3] object-cover group-hover:scale-105 transition-transform duration-700">
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    <%
                                    const daysDiff = (new Date() - new Date(anime.updatedAt)) / (1000 * 60 * 60 * 24);
                                    if(daysDiff <= 3) { %>
                                    <div class="absolute top-1.5 left-1.5 bg-green-600/90 backdrop-blur-md text-[8px] md:text-[9px] font-black text-white px-2 py-0.5 rounded border border-white/10">
                                        UPDATED
                                    </div>
                                    <% } %>
                                </div>
                                <p class="mt-2 text-white text-[11px] md:text-sm font-bold text-center line-clamp-2 leading-tight h-7 md:h-10 group-hover:text-blue-400">
                                    <%= anime.name %>
                                </p>
                            </a>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } }) %>
    </section>
    <% } %>

    <!-- NORMAL GENRES -->
    <% normalGenres.forEach(genre => {
        let genreAnimes = animes.filter(anime => anime.genres.some(g => g._id.toString() === genre._id.toString()));
        if(genreAnimes.length > 0) { %>
        <div class="mb-6 md:mb-10">
            <div class="flex justify-between items-center mb-3 px-1">
                <div class="flex items-center gap-2">
                    <div class="text-blue-500 font-black text-lg md:text-xl">#</div>
                    <h2 class="text-sm md:text-xl font-black text-white tracking-tight capitalize">
                        <%= genre.name %>
                    </h2>
                </div>
                <a href="/search?genre=<%= genre._id %>" class="text-gray-500 text-[10px] md:text-[11px] font-black uppercase tracking-widest hover:text-white transition-colors">
                    View All →
                </a>
            </div>

            <div class="anime-scroll flex gap-3 md:gap-5 overflow-x-auto pb-4 snap-x">
                <% genreAnimes.forEach(anime => { %>
                    <div class="anime-card-glass flex-shrink-0 w-[130px] sm:w-[140px] md:w-48 snap-center p-1 md:p-1.5 rounded-xl">
                        <a href="/anime/<%= anime._id %>" class="group">
                            <div class="relative rounded-lg md:rounded-2xl overflow-hidden border border-white/5 shadow-2xl">
                                <img src="<%= anime.imageUrl %>" class="w-full aspect-[2/3] object-cover group-hover:scale-105 transition-transform duration-700">
                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            </div>
                            <p class="mt-2 text-white text-[11px] md:text-sm font-bold text-center line-clamp-2 leading-tight h-7 md:h-10 group-hover:text-blue-400">
                                <%= anime.name %>
                            </p>
                        </a>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } }) %>

    <!-- MOVIE GENRES -->
    <% if(movieGenres && movieGenres.length > 0) { %>
    <div class="my-12 border-t-2 border-red-500/30 relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#0b0e11] px-4">
            <span class="text-red-500 text-xs font-black uppercase whitespace-nowrap">Anime Movies Section</span>
        </div>
    </div>

    <section class="mt-8 mb-8">
        <div class="flex items-center gap-2 mb-4 md:mb-6">
            <div class="w-1 h-5 md:w-1.5 md:h-8 bg-red-600 rounded-full shadow-[0_0_10px_rgba(239,68,68,0.5)]"></div>
            <h2 class="text-base md:text-2xl font-black text-white tracking-tight">Anime Movies</h2>
        </div>

        <% movieGenres.forEach(genre => {
            let genreAnimes = animes.filter(anime => anime.genres.some(g => g._id.toString() === genre._id.toString()));
            if(genreAnimes.length > 0) { %>
            <div class="mb-6 md:mb-10">
                <div class="flex justify-between items-center mb-3 px-1">
                    <div class="flex items-center gap-2">
                        <div class="text-red-500 font-black text-lg md:text-xl">#</div>
                        <h2 class="text-sm md:text-xl font-black text-white tracking-tight capitalize">
                            <%= genre.name %>
                        </h2>
                    </div>
                    <a href="/search?genre=<%= genre._id %>" class="text-gray-500 text-[10px] md:text-[11px] font-black uppercase tracking-widest hover:text-white transition-colors">
                        View All →
                    </a>
                </div>

                <div class="anime-scroll flex gap-3 md:gap-5 overflow-x-auto pb-4 snap-x justify-start">
                    <% genreAnimes.forEach(anime => { %>
                        <div class="anime-card-glass flex-shrink-0 w-[130px] sm:w-[140px] md:w-48 snap-center p-1 md:p-1.5 rounded-xl">
                            <a href="/anime/<%= anime._id %>" class="group">
                                <div class="relative rounded-lg md:rounded-2xl overflow-hidden border border-white/5 shadow-2xl">
                                    <img src="<%= anime.imageUrl %>" class="w-full aspect-[2/3] object-cover group-hover:scale-105 transition-transform duration-700">
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    
                                    
                                    <div class="absolute top-1 right-1 bg-red-600/80 backdrop-blur-md text-[8px] md:text-[9px] font-black text-white px-2 py-0.5 rounded border border-white/10">
                           MOVIE
                                </div>
                          </div> <!-- ← Ye closing div missing tha -->
                      <p class="mt-2 text-white text-[11px] md:text-sm font-bold text-center line-clamp-2 leading-tight h-7 md:h-10 group-hover:text-red-400">
                       <%= anime.name %>
                       </p>
                       </a>
                       </div>

                        
                    <% }) %>
                </div>
            </div>
        <% } }) %>
    </section>
    <% } %>

    <% } %>

    <div class="mt-12 mb-8 md:mt-20 md:mb-10 flex justify-center px-2">
        <div class="w-full max-w-xl bg-gradient-to-br from-[#151b23] to-[#0b0e11] border border-white/5 rounded-[2rem] md:rounded-[2.5rem] p-8 md:p-14 text-center shadow-2xl relative overflow-hidden group">
            <h2 class="text-lg md:text-3xl font-black text-white mb-2 md:mb-4">
                Need to reach <span class="text-blue-500">us?</span>
            </h2>
            <p class="text-gray-400 text-[10px] md:text-base leading-relaxed mb-6">
                Send a message directly to the admin team and we'll get back to you soon.
            </p>
            <a href="/contact-us" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white text-[10px] md:text-base font-black py-3 md:py-4 px-8 md:px-12 rounded-xl md:rounded-2xl transition-all hover:-translate-y-1 shadow-xl shadow-blue-900/20">
                <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7 8.941L21 8M5 19h14a2 0 002-2V7a2 0 00-2-2H5a2 0 00-2 2v10a2 0 002 2z"></path>
                </svg>
                CONTACT ADMIN
            </a>
        </div>
    </div>
</div>

<%- include('popular') %>

<!-- INDIAN RELEASE SCHEDULE -->
<section class="mt-8 mb-8 md:mt-12 md:mb-12 px-2 md:px-8">
    <div class="max-w-7xl mx-auto">
        <div class="mt-6 text-center">
            <div class="inline-block bg-gradient-to-r from-yellow-500/10 via-amber-500/10 to-yellow-500/10 border border-yellow-400/30 rounded-2xl px-6 py-3 backdrop-blur-sm shadow-lg shadow-yellow-500/10">
                <p class="text-[10px] md:text-[12px] text-yellow-400 font-black uppercase tracking-wider flex items-center justify-center gap-2 mb-1.5">
                    <span class="animate-pulse">⚠️</span>
                    <span>* Estimated timings. Actual release may vary</span>
                </p>
                <p class="text-[9px] md:text-[11px] text-white/70 font-semibold leading-relaxed">
                    The anime shown in this chart may not all be available on our website due to licensing & source unavailability
                </p>
            </div>
        </div>

        <div class="glass-panel rounded-2xl md:rounded-3xl p-4 md:p-6 border border-white/5 mt-4">
            <div class="flex items-center justify-between mb-4 md:mb-6">
                <div>
                    <h2 class="text-base md:text-2xl font-black text-white tracking-tight flex items-center gap-2">
                        <div class="w-1 h-5 md:w-1.5 md:h-8 bg-orange-600 rounded-full"></div>
                        Release Schedule
                    </h2>
                    <p class="text-[10px] md:text-xs text-gray-500 font-bold mt-1 uppercase">
                        Timings in IST - Data from AniList
                    </p>
                </div>
            </div>

            <div class="flex gap-1.5 md:gap-2 mb-4 md:mb-6 overflow-x-auto pb-2 anime-scroll">
                <button data-day="Monday" class="day-tab active-day text-[10px] md:text-xs font-black px-3 md:px-5 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap">Monday</button>
                <button data-day="Tuesday" class="day-tab text-[10px] md:text-xs font-black px-3 md:px-5 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap">Tuesday</button>
                <button data-day="Wednesday" class="day-tab text-[10px] md:text-xs font-black px-3 md:px-5 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap">Wednesday</button>
                <button data-day="Thursday" class="day-tab text-[10px] md:text-xs font-black px-3 md:px-5 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap">Thursday</button>
                <button data-day="Friday" class="day-tab text-[10px] md:text-xs font-black px-3 md:px-5 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap">Friday</button>
                <button data-day="Saturday" class="day-tab text-[10px] md:text-xs font-black px-3 md:px-5 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap">Saturday</button>
                <button data-day="Sunday" class="day-tab text-[10px] md:text-xs font-black px-3 md:px-5 py-2 md:py-2.5 rounded-lg md:rounded-xl transition-all whitespace-nowrap">Sunday</button>
            </div>

            <div id="schedule-content">
                <div class="text-center py-10 text-gray-500">
                    <i class="fas fa-spinner fa-spin text-2xl mb-2"></i>
                    <p class="text-sm font-bold">Loading Schedule...</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
let scheduleData = {};
let currentDay = 'Monday';

function getCurrentISTDay() {
    const now = new Date();
    const istOffset = 5.5 * 60 * 60 * 1000;
    const istDate = new Date(now.getTime() + istOffset);
    const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    return days[istDate.getUTCDay()];
}

async function loadSchedule() {
    try {
        const res = await fetch('/api/upcoming-schedule');
        scheduleData = await res.json();
        currentDay = getCurrentISTDay();
        document.querySelectorAll('.day-tab').forEach(tab => {
            tab.classList.remove('active-day');
            if (tab.dataset.day === currentDay) tab.classList.add('active-day');
        });
        renderDaySchedule(currentDay);
    } catch (err) {
        console.error('Schedule load error:', err);
        document.getElementById('schedule-content').innerHTML = '<div class="text-center py-10 text-red-500 text-sm font-bold">Failed to load schedule</div>';
    }
}

function renderDaySchedule(day) {
    const content = document.getElementById('schedule-content');
    const shows = scheduleData[day] || [];
    if (shows.length === 0) {
        content.innerHTML = `<div class="text-center py-10"><div class="text-4xl mb-2">📅</div><p class="text-gray-500 text-sm font-bold">No shows scheduled for ${day}</p></div>`;
        return;
    }
    content.innerHTML = `
        <div class="mb-3">
            <h3 class="text-sm md:text-lg font-black text-orange-500 uppercase tracking-tight">${day} Schedule</h3>
        </div>
        <div class="space-y-2 md:space-y-3">
            ${shows.map(show => `
                <div class="schedule-item flex items-center gap-3 md:gap-4 p-2 md:p-3 rounded-xl bg-white/[0.03] border border-white/5 hover:bg-white/[0.06] hover:border-orange-500/30 transition-all">
                    <img src="${show.image}" class="w-12 h-16 md:w-16 md:h-20 object-cover rounded-lg flex-shrink-0">
                    <div class="flex-1 min-w-0">
                        <h4 class="text-white text-xs md:text-sm font-bold line-clamp-1 mb-0.5">${show.title}</h4>
                        <p class="text-orange-500 text-[10px] md:text-xs font-black uppercase">Episode ${show.episode} - NEW EPISODE</p>
                    </div>
                    <div class="text-right flex-shrink-0">
                        <div class="text-white text-sm md:text-lg font-black">${show.time}</div>
                        <div class="text-gray-500 text-[10px] md:text-[11px] font-bold uppercase">IST</div>
                    </div>
                </div>
            `).join('')}
        </div>
    `;
}

document.querySelectorAll('.day-tab').forEach(tab => {
    tab.addEventListener('click', () => {
        document.querySelectorAll('.day-tab').forEach(t => t.classList.remove('active-day'));
        tab.classList.add('active-day');
        currentDay = tab.dataset.day;
        renderDaySchedule(currentDay);
    });
});

loadSchedule();
</script>

<%- include('partials/footer') %>

<script type="application/json" id="animes-data">
    <%- JSON.stringify(animes.map(anime => ({ name: anime.name, id: anime._id }))) %>
</script>

<script type="application/json" id="user-data">
    <%- JSON.stringify({ userId: session.userId || session.adminId || null, isLoggedIn:!!(session.userId || session.adminId) }) %>
</script>

<script>
    const fullAnimeList = JSON.parse(document.getElementById('animes-data').textContent);
    const userData = JSON.parse(document.getElementById('user-data').textContent);
    const searchInput = document.getElementById('search-input');
    const suggestionsDiv = document.getElementById('suggestions');

    searchInput.addEventListener('input', () => {
        const query = searchInput.value.trim().toLowerCase();
        suggestionsDiv.innerHTML = '';
        suggestionsDiv.classList.add('hidden');
        if (query.length === 0) return;
        const filtered = fullAnimeList.filter(a => a.name.toLowerCase().includes(query)).slice(0, 10);
        if (filtered.length === 0) return;
        filtered.forEach(a => {
            const div = document.createElement('div');
            div.className = 'p-3 hover:bg-white/10 cursor-pointer text-white text-sm font-medium transition-all border-b border-white/5';
            div.textContent = a.name;
            div.onclick = () => {
                searchInput.value = a.name;
                suggestionsDiv.classList.add('hidden');
                document.getElementById('search-form').submit();
            };
            suggestionsDiv.appendChild(div);
        });
        suggestionsDiv.classList.remove('hidden');
    });

    document.onclick = (e) => {
        if (!searchInput.contains(e.target) &&!suggestionsDiv.contains(e.target)) {
            suggestionsDiv.classList.add('hidden');
        }
    };

    const HISTORY_KEY = `watchHistory_${userData.userId || 'guest'}`;
    const MAX_HISTORY = 20;

    function getWatchHistory() {
        if (!userData.isLoggedIn) return [];
        const data = localStorage.getItem(HISTORY_KEY);
        return data? JSON.parse(data) : [];
    }

    function saveToHistory(animeData) {
        if (!userData.isLoggedIn) return;
        let history = getWatchHistory();
        history = history.filter(item => item.animeId!== animeData.animeId);
        history.unshift({...animeData, watchedAt: Date.now() });
        history = history.slice(0, MAX_HISTORY);
        localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
        renderWatchHistory();
    }

    function renderWatchHistory() {
        const history = getWatchHistory();
        const section = document.getElementById('watch-history-section');
        const grid = document.getElementById('watch-history-grid');
        if (history.length === 0 ||!userData.isLoggedIn) {
            section.classList.add('hidden');
            return;
        }
        section.classList.remove('hidden');
        grid.innerHTML = '';
        const uniqueAnimes = {};
        history.forEach(item => {
            if (!uniqueAnimes[item.animeId] || uniqueAnimes[item.animeId].watchedAt < item.watchedAt) {
                uniqueAnimes[item.animeId] = item;
            }
        });
        const displayItems = Object.values(uniqueAnimes).sort((a, b) => b.watchedAt - a.watchedAt);
        displayItems.forEach((item, index) => {
            if (index >= 8) return;
            const hideClass = index >= 6? 'hidden lg:block' : '';
            const isMovie = item.type === 'movie';
            const card = document.createElement('div');
            card.className = `episode-glass-card group cursor-pointer p-1 rounded-lg md:rounded-xl border border-white/5 transition-all ${hideClass}`;
            card.innerHTML = `
                <a href="/anime/${item.animeId}" class="block">
                    <div class="relative aspect-video overflow-hidden rounded-md md:rounded-lg">
                        <img src="${item.animeImg}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        ${isMovie? `
                            <div class="absolute top-0.5 left-0.5 md:top-1 md:left-1 bg-red-600/90 backdrop-blur-md text-[8px] md:text-[9px] font-black text-white px-2 py-0.5 rounded border border-white/10 uppercase">
                                MOVIE
                            </div>
                        ` : `
                            <div class="absolute top-0.5 left-0.5 md:top-1 md:left-1 bg-black/80 backdrop-blur-md text-[8px] md:text-[9px] font-black text-white px-1.5 py-0.5 rounded border border-white/10 uppercase">
                                S${item.season} E${item.episode}
                            </div>
                        `}
                        <div class="absolute top-0.5 right-0.5 md:top-1 md:right-1 bg-purple-600/80 backdrop-blur-md text-[8px] md:text-[9px] font-black text-white px-1.5 py-0.5 rounded">
                            CONTINUE
                        </div>
                    </div>
                    <div class="mt-1.5 text-center">
                        <h3 class="text-white text-[11px] md:text-xs font-bold line-clamp-2 leading-tight h-7 md:h-8">
                            ${item.animeName}
                        </h3>
                        <p class="text-gray-500 text-[9px] md:text-[10px] uppercase font-black tracking-tighter">
                            ${isMovie? 'Film' : `Ep ${item.episode}`}
                                                </p>
                    </div>
                </a>
            `;
            grid.appendChild(card);
        });
    }

    document.getElementById('clear-history-btn').addEventListener('click', function() {
        Swal.fire({
            title: 'Wipe History?',
            text: "This will permanently clear your recently watched anime.",
            icon: 'warning',
            background: '#0b0e11',
            color: '#ffffff',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#1f2937',
            confirmButtonText: 'Yes, clear it!',
            customClass: {
                popup: 'rounded-2xl border border-white/10 shadow-2xl'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                localStorage.removeItem(HISTORY_KEY);
                renderWatchHistory();
                Swal.fire({
                    title: 'Cleared!',
                    text: 'Your watch history has been deleted.',
                    icon: 'success',
                    background: '#0b0e11',
                    color: '#ffffff',
                    confirmButtonColor: '#3b82f6',
                    timer: 2000,
                    customClass: {
                        popup: 'rounded-2xl border border-white/10'
                    }
                });
            }
        })
    });

    // FIX: data-type bhi capture karo for Watch History
    document.querySelectorAll('.episode-glass-card').forEach(card => {
        card.addEventListener('click', (e) => {
            const animeId = card.dataset.animeId;
            const animeName = card.dataset.animeName;
            const animeImg = card.dataset.animeImg;
            const season = card.dataset.season;
            const episode = card.dataset.episode;
            const type = card.dataset.type; // ← NEW

            if (animeId && animeName) {
                saveToHistory({
                    animeId,
                    animeName,
                    animeImg,
                    season: parseInt(season),
                    episode: parseInt(episode),
                    type: type || 'series' // ← NEW
                });
            }
        });
    });

    renderWatchHistory();

    // Custom Genre Dropdown Logic
    const genreToggle = document.getElementById('genre-toggle');
    const genreMenu = document.getElementById('genre-menu');
    const genreInput = document.getElementById('genre-input');
    const genreLabel = document.getElementById('genre-label');
    const genreArrow = document.getElementById('genre-arrow');

    if (genreToggle) {
        genreToggle.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const isHidden = genreMenu.classList.contains('hidden');

            if (isHidden) {
                genreMenu.classList.remove('hidden');
                genreArrow.classList.add('rotated');
            } else {
                genreMenu.classList.add('hidden');
                genreArrow.classList.remove('rotated');
            }
        });
    }

    document.querySelectorAll('.genre-option').forEach(option => {
        option.addEventListener('click', (e) => {
            e.stopPropagation();
            const value = option.dataset.value;
            const text = option.textContent.trim();

            genreInput.value = value;
            genreLabel.textContent = value? text : 'Genre';

            document.querySelectorAll('.genre-option').forEach(opt => {
                opt.classList.remove('bg-blue-500/10', 'text-blue-400');
            });
            option.classList.add('bg-blue-500/10', 'text-blue-400');

            genreMenu.classList.add('hidden');
            genreArrow.classList.remove('rotated');

            if (value) {
                document.getElementById('search-input').value = '';
                document.getElementById('search-form').submit();
            }
        });
    });

    document.addEventListener('click', (e) => {
        if (genreToggle &&!genreToggle.contains(e.target) &&!genreMenu.contains(e.target)) {
            genreMenu.classList.add('hidden');
            genreArrow.classList.remove('rotated');
        }
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            genreMenu.classList.add('hidden');
            genreArrow.classList.remove('rotated');
        }
    });
</script>

<style>
body { background-color: #0b0e11; color: #fff; overflow-x: hidden; }

/* MODERN SEARCH BAR - Z-INDEX FIXED */
.search-modern {
    background: rgba(15, 20, 25, 0.9);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1.5px solid rgba(59, 130, 246, 0.25);
    border-radius: 20px;
    box-shadow:
        0 4px 24px rgba(0, 0, 0, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
    position: relative;
    transform: translateZ(0);
    z-index: 50;
}

.search-modern::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 20px;
    padding: 1.5px;
    background: linear-gradient(135deg,
        rgba(59, 130, 246, 0.6),
        rgba(147, 51, 234, 0.5),
        rgba(236, 72, 153, 0.4),
        rgba(59, 130, 246, 0.6));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
}

.search-modern:focus-within {
    border-color: rgba(59, 130, 246, 0.6);
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(59, 130, 246, 0.4),
        0 0 40px rgba(59, 130, 246, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transform: translateY(-1px) translateZ(0);
}

.search-modern:focus-within::after {
    opacity: 1;
}

#search-input {
    font-weight: 600;
    letter-spacing: 0.01em;
    -webkit-appearance: none;
    appearance: none;
}

#search-input::placeholder {
    color: rgba(107, 114, 128, 0.7);
    font-weight: 600;
}

/* Custom Genre Dropdown - WITH GLOWING ARROWS */
.custom-genre-dropdown {
    position: relative;
    z-index: 100;
}

.custom-genre-dropdown button {
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    -webkit-user-select: none;
}

/* Main Button Arrow - Always Glowing */
#genre-arrow {
    color: #60a5fa;
    filter: drop-shadow(0 0 6px rgba(96, 165, 250, 1))
            drop-shadow(0 0 12px rgba(59, 130, 246, 0.8))
            drop-shadow(0 0 20px rgba(59, 130, 246, 0.6));
    transition: all 0.3s ease;
}

.group:hover #genre-arrow {
    color: #93c5fd;
    filter: drop-shadow(0 0 10px rgba(147, 197, 253, 1))
            drop-shadow(0 0 20px rgba(59, 130, 246, 1))
            drop-shadow(0 0 30px rgba(59, 130, 246, 0.8));
    transform: scale(1.1);
}

#genre-arrow.rotated {
    transform: rotate(180deg) scale(1.1);
    color: #3b82f6;
    filter: drop-shadow(0 0 12px rgba(59, 130, 246, 1))
            drop-shadow(0 0 24px rgba(59, 130, 246, 0.9))
            drop-shadow(0 0 36px rgba(59, 130, 246, 0.7));
}

#genre-menu {
    animation: dropdownSlide 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: top right;
    will-change: transform, opacity;
    backface-visibility: hidden;
    -webkit-font-smoothing: antialiased;
    z-index: 9999;
}

@keyframes dropdownSlide {
    0% { opacity: 0; transform: scale(0.95) translateY(-8px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
}

#genre-menu::-webkit-scrollbar {
    width: 4px;
}

#genre-menu::-webkit-scrollbar-track {
    background: rgba(10, 14, 18, 0.8);
}

#genre-menu::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.7);
    border-radius: 10px;
    box-shadow: 0 0 8px rgba(59, 130, 246, 0.5);
}

#genre-menu::-webkit-scrollbar-thumb:hover {
    background: rgba(59, 130, 246, 0.9);
    box-shadow: 0 0 12px rgba(59, 130, 246, 0.8);
}

.genre-option {
    will-change: background-color;
    -webkit-tap-highlight-color: transparent;
}

.genre-option:last-child {
    border-bottom: none;
}

/* Scroll Indicator - Extra Glowing */
@keyframes bounce {
    0%, 100% { transform: translateY(0); opacity: 0.8; }
    50% { transform: translateY(-6px); opacity: 1; }
}

.animate-bounce {
    animation: bounce 1.5s infinite;
    color: #60a5fa;
    filter: drop-shadow(0 0 8px rgba(96, 165, 250, 1))
            drop-shadow(0 0 16px rgba(59, 130, 246, 0.9))
            drop-shadow(0 0 24px rgba(59, 130, 246, 0.7));
}

/* Search Button */
.search-modern button[type="submit"] {
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    -webkit-tap-highlight-color: transparent;
    will-change: transform;
}

.search-modern button[type="submit"]:hover {
    filter: brightness(1.15);
}

.search-modern button[type="submit"]:active {
    transform: scale(0.94);
}

/* Suggestions */
#suggestions {
    max-height: 350px;
    overflow-y: auto;
    will-change: transform;
    z-index: 9998;
}

#suggestions::-webkit-scrollbar {
    width: 5px;
}

#suggestions::-webkit-scrollbar-track {
    background: rgba(10, 14, 18, 0.6);
}

#suggestions::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.5);
    border-radius: 10px;
}

#suggestions div {
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    transition: background-color 0.2s ease, padding-left 0.2s ease;
    font-weight: 600;
    -webkit-tap-highlight-color: transparent;
    will-change: background-color;
}

#suggestions div:hover {
    background: rgba(59, 130, 246, 0.12);
    padding-left: 20px;
    color: #60a5fa;
}

#suggestions div:last-child {
    border-bottom: none;
}

/* Cards & Panels */
.glass-panel { background: rgba(21, 27, 35, 0.4); border: 1px solid rgba(255, 255, 255, 0.05); }
.anime-card-glass { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); transition: 0.3s; }
.anime-card-glass:hover { transform: translateY(-4px); background: rgba(255, 255, 255, 0.04); border-color: rgba(59, 130, 246, 0.3); box-shadow: 0 10px 30px rgba(59, 130, 246, 0.2); }
.episode-glass-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); }
.episode-glass-card:hover { background: rgba(255, 255, 255, 0.05); border-color: rgba(59, 130, 246, 0.4); transform: translateY(-2px); }

.anime-scroll { -ms-overflow-style: none; scrollbar-width: none; }
.anime-scroll::-webkit-scrollbar { display: none; }

@keyframes suggestionDrop {
    0% { opacity: 0; transform: translate(-50%, -10px) scale(0.96); }
    100% { opacity: 1; transform: translate(-50%, 0) scale(1); }
}
.animate-suggestion-drop { animation: suggestionDrop 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards; }

.line-clamp-1 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    line-clamp: 1;
}

.line-clamp-2 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
}

/* Day Tabs - Schedule */
.day-tab {
    background: rgba(255, 255, 255, 0.03);
    color: #6b7280;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.day-tab:hover {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
}

.active-day {
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.2), rgba(249, 115, 22, 0.15));
    color: #fb923c;
    border-color: rgba(251, 146, 60, 0.3);
    box-shadow: 0 0 20px rgba(251, 146, 60, 0.2);
}

/* Mobile Optimization */
@media (max-width: 640px) {
    .anime-card-glass { padding: 0.25rem; background: transparent; border: none; }
    .anime-card-glass:hover { transform: none; box-shadow: none; background: transparent; }

    .search-modern {
        border-radius: 18px;
        padding-left: 12px;
        padding-right: 12px;
    }

    .search-modern::after {
        border-radius: 18px;
    }

    #genre-label {
        max-width: 55px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    #genre-menu {
        width: 180px;
        right: -8px;
        max-height: 60vh;
    }

    .genre-option {
        font-size: 10px;
        padding: 10px 12px;
    }

    #genre-arrow {
        width: 10px;
        height: 10px;
    }
    
    /* Bigger cards like Toonstream */
    .anime-scroll { gap: 12px !important; padding-left: 4px; }
}

/* SweetAlert2 Custom */
.swal2-popup {
    font-family: 'Inter', sans-serif!important;
}

.swal2-title {
    font-weight: 900!important;
    text-transform: uppercase!important;
    letter-spacing: -0.02em!important;
}
</style>
